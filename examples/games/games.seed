snakeCard = snakeCard + "<span class=\"kv\">AI�?b id=\"snakeAI\">存活</b></span>"
snakeCard = snakeCard + "<span class=\"kv\">FPS�?b id=\"snakeFps\">0</b></span>"
snakeCard = snakeCard + "</div>"
