title = "SeedLang 游戏性能场景"
subtitle = "十大演示：展示交互、动画和实时更新能力"
hint = "动作游戏 + 街机游戏 + 弹幕游戏 + 休闲演示"

styles = "<style>"
styles = styles + ":root{--bg:#060a18;--bg2:#121b3d;--ink:#e7edff;--muted:#9fb0df;--line:rgba(160,180,255,.24);--brand:#4f7cff;--brand2:#8d56ff;--ok:#22d3a4;--danger:#ff5d73;--warn:#ffb86b;--info:#7dd3fc;}"
styles = styles + "*{box-sizing:border-box}body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;color:var(--ink);background:radial-gradient(circle at 20% -10%,#27408f 0,transparent 32%),radial-gradient(circle at 90% -20%,#522693 0,transparent 30%),linear-gradient(145deg,var(--bg),var(--bg2));min-height:100vh}"
styles = styles + ".wrap{max-width:1400px;margin:0 auto;padding:22px}.nav{display:flex;justify-content:space-between;align-items:center;border:1px solid var(--line);border-radius:14px;background:rgba(11,18,44,.55);padding:10px 14px}.nav a{color:#b8ccff;text-decoration:none;transition:color .2s}.nav a:hover{color:#fff}"
styles = styles + ".hero{margin-top:16px;padding:18px;border:1px solid var(--line);border-radius:16px;background:rgba(10,18,45,.52)}"
styles = styles + ".title{margin:8px 0 8px;font-size:36px}.muted{color:var(--muted);margin:0;line-height:1.65}"
styles = styles + ".grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:16px}.grid-full{grid-column:1/-1}"
styles = styles + ".card{border:1px solid var(--line);border-radius:16px;background:rgba(9,16,40,.58);padding:14px;box-shadow:0 10px 28px rgba(3,7,20,.35);transition:all .3s ease}"
styles = styles + ".card:hover{border-color:rgba(160,180,255,.4);transform:translateY(-2px)}"
styles = styles + ".head{display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:10px}.tag{padding:4px 10px;border-radius:999px;border:1px solid var(--line);font-size:12px;color:#c8d6ff}.tag-action{background:rgba(79,124,255,.2);border-color:rgba(79,124,255,.4)}.tag-puzzle{background:rgba(125,211,252,.2);border-color:rgba(125,211,252,.4)}.tag-reflex{background:rgba(255,184,107,.2);border-color:rgba(255,184,107,.4)}.tag-boss{background:rgba(168,107,255,.2);border-color:rgba(168,107,255,.4)}.tag-arcade{background:rgba(34,211,164,.2);border-color:rgba(34,211,164,.4)}.tag-bullet{background:rgba(255,107,138,.2);border-color:rgba(255,107,138,.4)}.tag-relax{background:rgba(139,92,246,.2);border-color:rgba(139,92,246,.4)}"
styles = styles + ".btn{border:0;border-radius:10px;padding:9px 12px;cursor:pointer;background:linear-gradient(90deg,var(--brand),var(--brand2));color:#fff;font-weight:700;transition:all .2s}.btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(79,124,255,.4)}"
styles = styles + ".status{margin-top:10px;font-size:13px;color:#c7d5ff}.good{color:var(--ok)}.bad{color:var(--danger)}.warn{color:var(--warn)}"
styles = styles + "canvas{width:100%;height:auto;border:1px solid var(--line);border-radius:12px;background:#050913;display:block}"
styles = styles + ".panel{display:flex;gap:8px;flex-wrap:wrap;align-items:center}.kv{font-size:12px;padding:5px 8px;border:1px solid var(--line);border-radius:999px;color:#cad8ff}"
styles = styles + ".memory-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:10px}.memory-card{aspect-ratio:1;border:1px solid var(--line);border-radius:10px;background:rgba(20,30,60,.6);display:flex;align-items:center;justify-content:center;font-size:28px;cursor:pointer;transition:all .3s ease;user-select:none}"
styles = styles + ".memory-card:hover{border-color:rgba(160,180,255,.5);background:rgba(30,45,80,.7)}.memory-card.flipped{background:rgba(79,124,255,.25);border-color:var(--brand)}.memory-card.matched{background:rgba(34,211,164,.2);border-color:var(--ok);pointer-events:none}"
styles = styles + ".reveal{opacity:0;transform:translateY(18px);transition:all .6s ease}.reveal.show{opacity:1;transform:none}"
styles = styles + ".section-title{grid-column:1/-1;margin-top:20px;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid var(--line);font-size:18px;color:var(--muted)}"
styles = styles + ".seed-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:rgba(79,124,255,.15);border:1px solid rgba(79,124,255,.3);border-radius:4px;font-size:11px;color:#a8c4ff;margin-left:8px}"
styles = styles + "@media (max-width:1100px){.grid{grid-template-columns:1fr}}@media (max-width:640px){.title{font-size:28px}.memory-grid{grid-template-columns:repeat(3,1fr)}}"
styles = styles + "</style>"

snakeCard = "<article class=\"card reveal\">"
snakeCard = snakeCard + "<div class=\"head\"><h3 style=\"margin:0\">DEMO 1：贪吃蛇</h3><span class=\"tag tag-action\">动作 / 策略</span></div>"
