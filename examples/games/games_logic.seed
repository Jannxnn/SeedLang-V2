tower = { running: false wave: 1 gold: 100 lives: 20 kills: 0 towers: [] enemies: [] bullets: [] path: [] gridSize: 40 cols: 18 rows: 10 spawnTimer: 0 enemiesSpawned: 0 enemiesPerWave: 5 }

fn towerInit() {
  tower.path = [{ x: 0 y: 5 } { x: 4 y: 5 } { x: 4 y: 2 } { x: 8 y: 2 } { x: 8 y: 7 } { x: 12 y: 7 } { x: 12 y: 3 } { x: 17 y: 3 }]
  tower.towers = []
  tower.enemies = []
  tower.bullets = []
  tower.wave = 1
  tower.gold = 100
  tower.lives = 20
  tower.kills = 0
  tower.spawnTimer = 0
  tower.enemiesSpawned = 0
  tower.enemiesPerWave = 5
  tower.running = false
}

fn towerStartWave() {
  if tower.running {
    return
  }
  tower.running = true
  tower.spawnTimer = 0
  tower.enemiesSpawned = 0
  tower.enemiesPerWave = 5 + tower.wave * 2
}

fn towerSpawnEnemy() {
  types = ["normal" "fast" "tank" "boss"]
  type = types[floor(random() * 4)]
  
  hp = 30 + tower.wave * 10
  speed = 1
  reward = 10
  
  if type == "fast" {
    hp = 20 + tower.wave * 5
    speed = 2
    reward = 15
  }
  
  if type == "tank" {
    hp = 80 + tower.wave * 20
    speed = 0.5
    reward = 25
  }
  
  if type == "boss" {
    hp = 200 + tower.wave * 50
    speed = 0.3
    reward = 50
  }
  
  tower.enemies.push({ x: tower.path[0].x * tower.gridSize y: tower.path[0].y * tower.gridSize hp: hp maxHp: hp speed: speed reward: reward type: type pathIndex: 0 })
}

fn towerAddTower(gx gy) {
  if tower.gold < 30 {
    return false
  }
  
  for (i = 0; i < len(tower.towers); i = i + 1) {
    t = tower.towers[i]
    if t.gx == gx && t.gy == gy {
      return false
    }
  }
  
  for (i = 0; i < len(tower.path); i = i + 1) {
    p = tower.path[i]
    if p.x == gx && p.y == gy {
      return false
    }
  }
  
  tower.gold = tower.gold - 30
  tower.towers.push({ gx: gx gy: gy x: gx * tower.gridSize + tower.gridSize/2 y: gy * tower.gridSize + tower.gridSize/2 range: 120 damage: 10 fireRate: 30 fireCooldown: 0 level: 1 })
  return true
}

fn towerUpgradeTower(index) {
  if index < 0 || index >= len(tower.towers) {
    return
  }
  
  t = tower.towers[index]
  cost = t.level * 20
  
  if tower.gold < cost {
    return
  }
  
  tower.gold = tower.gold - cost
  t.level = t.level + 1
  t.damage = t.damage + 5
  t.range = t.range + 10
  t.fireRate = t.fireRate - 2
  if t.fireRate < 10 {
    t.fireRate = 10
  }
}

fn towerStep() {
  if !tower.running {
    return { wave: tower.wave gold: tower.gold lives: tower.lives kills: tower.kills towerCount: len(tower.towers) enemyCount: len(tower.enemies) gameOver: false victory: false }
  }
  
  tower.spawnTimer = tower.spawnTimer + 1
  if tower.spawnTimer >= 60 && tower.enemiesSpawned < tower.enemiesPerWave {
    towerSpawnEnemy()
    tower.spawnTimer = 0
    tower.enemiesSpawned = tower.enemiesSpawned + 1
  }
  
  for (i = 0; i < len(tower.enemies); i = i + 1) {
    e = tower.enemies[i]
    
    if e.pathIndex < len(tower.path) - 1 {
      target = tower.path[e.pathIndex + 1]
      tx = target.x * tower.gridSize + tower.gridSize/2
      ty = target.y * tower.gridSize + tower.gridSize/2
      
      dx = tx - e.x
      dy = ty - e.y
      dist = sqrt(dx*dx + dy*dy)
      
      if dist < e.speed * 2 {
        e.pathIndex = e.pathIndex + 1
      } else {
        e.x = e.x + dx / dist * e.speed
        e.y = e.y + dy / dist * e.speed
      }
    } else {
      tower.lives = tower.lives - 1
      tower.enemies.splice(i 1)
      i = i - 1
      
      if tower.lives <= 0 {
        tower.running = false
        return { wave: tower.wave gold: tower.gold lives: 0 kills: tower.kills towerCount: len(tower.towers) enemyCount: len(tower.enemies) gameOver: true victory: false }
      }
    }
  }
  
  for (i = 0; i < len(tower.towers); i = i + 1) {
    t = tower.towers[i]
    t.fireCooldown = t.fireCooldown - 1
    
    if t.fireCooldown <= 0 {
      target = null
      minDist = t.range
      
      for (j = 0; j < len(tower.enemies); j = j + 1) {
        e = tower.enemies[j]
        dx = e.x - t.x
        dy = e.y - t.y
        dist = sqrt(dx*dx + dy*dy)
        
        if dist < minDist {
          minDist = dist
          target = e
        }
      }
      
      if target != null {
        tower.bullets.push({ x: t.x y: t.y targetId: j damage: t.damage speed: 5 })
        t.fireCooldown = t.fireRate
      }
    }
  }
  
  for (i = len(tower.bullets) - 1; i >= 0; i = i - 1) {
    b = tower.bullets[i]
    
    if b.targetId >= len(tower.enemies) {
      tower.bullets.splice(i 1)
      continue
    }
    
    target = tower.enemies[b.targetId]
    dx = target.x - b.x
    dy = target.y - b.y
    dist = sqrt(dx*dx + dy*dy)
    
    if dist < 10 {
      target.hp = target.hp - b.damage
      
      if target.hp <= 0 {
        tower.gold = tower.gold + target.reward
        tower.kills = tower.kills + 1
        tower.enemies.splice(b.targetId 1)
      }
      
      tower.bullets.splice(i 1)
    } else {
      b.x = b.x + dx / dist * b.speed
      b.y = b.y + dy / dist * b.speed
    }
  }
  
  if len(tower.enemies) == 0 && tower.enemiesSpawned >= tower.enemiesPerWave {
    tower.wave = tower.wave + 1
    tower.gold = tower.gold + 20
    tower.running = false
    
    if tower.wave > 10 {
      return { wave: tower.wave gold: tower.gold lives: tower.lives kills: tower.kills towerCount: len(tower.towers) enemyCount: 0 gameOver: false victory: true }
    }
  }
  
  return { wave: tower.wave gold: tower.gold lives: tower.lives kills: tower.kills towerCount: len(tower.towers) enemyCount: len(tower.enemies) gameOver: false victory: false }
}

