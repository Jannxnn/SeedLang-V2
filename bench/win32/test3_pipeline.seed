MODE = 0
NUM = 80
FRAMES = 300
W = 640
H = 480

bx = []
by = []
bvx = []
bvy = []
br = []

fn init() {
    i = 0
    while i < NUM {
        push(bx 10 + floor(random() * (W - 20)))
        push(by 10 + floor(random() * (H - 20)))
        push(bvx floor((random() - 0.5) * 4))
        push(bvy floor((random() - 0.5) * 4))
        push(br 3 + floor(random() * 5))
        i = i + 1
    }
}

fn step() {
    i = 0
    while i < NUM {
        bx[i] = bx[i] + bvx[i]
        by[i] = by[i] + bvy[i]
        r = br[i]
        if bx[i] < r {
            bx[i] = r
            bvx[i] = -bvx[i]
        }
        if bx[i] > W - r {
            bx[i] = W - r
            bvx[i] = -bvx[i]
        }
        if by[i] < r {
            by[i] = r
            bvy[i] = -bvy[i]
        }
        if by[i] > H - r {
            by[i] = H - r
            bvy[i] = -bvy[i]
        }
        i = i + 1
    }
}

collisions = 0

fn collide() {
    collisions = 0
    i = 0
    while i < NUM {
        j = i + 1
        while j < NUM {
            dx = bx[j] - bx[i]
            dy = by[j] - by[i]
            d2 = dx * dx + dy * dy
            md = br[i] + br[j]
            if d2 < md * md {
                collisions = collisions + 1
            }
            j = j + 1
        }
        i = i + 1
    }
}

fn renderBalls() {
    i = 0
    while i < NUM {
        cx = bx[i]
        cy = by[i]
        r = br[i]
        dy = -r
        while dy <= r {
            dx = -r
            while dx <= r {
                if dx * dx + dy * dy <= r * r {
                    win32.setPixel(cx + dx cy + dy 255)
                }
                dx = dx + 1
            }
            dy = dy + 1
        }
        i = i + 1
    }
}

init()
f = 0
while f < FRAMES {
    if win32.pollEvents() == 0 {
        break
    }
    if MODE != 1 {
        step()
        collide()
    }
    if MODE != 0 {
        renderBalls()
    }
    win32.present()
    f = f + 1
}
print(f)
print(collisions)
