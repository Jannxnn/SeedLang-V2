// 场景测试 - partition problems：分割问题（字母区间/回文分割）
// EXPECT: "OK:4"
fn partitionLabels(s) {
    lastOccurrence = {}
    
    chars = split(s "")
    i = 0
    while i < len(chars) {
        lastOccurrence[chars[i]] = i
        i = i + 1
    }
    
    result = []
    start = 0
    end = 0
    
    i = 0
    while i < len(s) {
        c = charAt(s i)
        if lastOccurrence[c] > end { end = lastOccurrence[c] }
        
        if i == end {
            push(result end - start + 1)
            start = i + 1
        }
        i = i + 1
    }
    
    return result
}

fn labels(s) {
    return partitionLabels(s)
}

fn maxChunksToSorted(arr) {
    maxSoFar = 0
    chunks = 0
    
    i = 0
    while i < len(arr) {
        if arr[i] > maxSoFar { maxSoFar = arr[i] }
        
        if maxSoFar == i {
            chunks = chunks + 1
        }
        i = i + 1
    }
    
    return chunks
}

fn maxChunksToSorted2(arr) {
    maxLeft = []
    minRight = []
    
    currentMax = -999999
    for n in arr {
        if n > currentMax { currentMax = n }
        push(maxLeft currentMax)
    }
    
    currentMin = 999999
    i = len(arr) - 1
    while i >= 0 {
        if arr[i] < currentMin { currentMin = arr[i] }
        push(minRight currentMin)
        i = i - 1
    }
    minRight = reverse(minRight)
    
    chunks = 0
    i = 0
    while i < len(arr) - 1 {
        if maxLeft[i] <= minRight[i + 1] {
            chunks = chunks + 1
        }
        i = i + 1
    }
    
    return chunks + 1
}

passed = 0

parts = partitionLabels("ababcbacadefegdehijhklij")
if len(parts) == 3 && parts[0] == 9 { passed = passed + 1 }

if maxChunksToSorted([4 3 2 1 0]) == 1 { passed = passed + 1 }

if maxChunksToSorted([1 0 2 3 4]) == 4 { passed = passed + 1 }

if maxChunksToSorted2([2 1 3 4 4]) == 4 { passed = passed + 1 }

result = "OK:" + toString(passed)
