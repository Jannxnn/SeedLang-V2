// 场景测试 - matrix operations：矩阵乘法/转置等矩阵操作
// EXPECT: "OK:4"
class Matrix {
    init(rows cols) {
        this.rows = rows
        this.cols = cols
        this.data = []
        i = 0
        while i < rows {
            row = []
            j = 0
            while j < cols {
                push(row 0)
                j = j + 1
            }
            push(this.data row)
            i = i + 1
        }
    }
    
    set(row col value) {
        this.data[row][col] = value
    }
    
    get(row col) {
        return this.data[row][col]
    }
    
    add(other) {
        result = Matrix(this.rows this.cols)
        i = 0
        while i < this.rows {
            j = 0
            while j < this.cols {
                result.set(i j this.get(i j) + other.get(i j))
                j = j + 1
            }
            i = i + 1
        }
        return result
    }
    
    multiply(other) {
        result = Matrix(this.rows other.cols)
        i = 0
        while i < this.rows {
            j = 0
            while j < other.cols {
                sum = 0
                k = 0
                while k < this.cols {
                    sum = sum + this.get(i k) * other.get(k j)
                    k = k + 1
                }
                result.set(i j sum)
                j = j + 1
            }
            i = i + 1
        }
        return result
    }
    
    transpose() {
        result = Matrix(this.cols this.rows)
        i = 0
        while i < this.rows {
            j = 0
            while j < this.cols {
                result.set(j i this.get(i j))
                j = j + 1
            }
            i = i + 1
        }
        return result
    }
}

m1 = Matrix(2 2)
m1.set(0 0 1)
m1.set(0 1 2)
m1.set(1 0 3)
m1.set(1 1 4)

m2 = Matrix(2 2)
m2.set(0 0 5)
m2.set(0 1 6)
m2.set(1 0 7)
m2.set(1 1 8)

sum = m1.add(m2)
product = m1.multiply(m2)
transposed = m1.transpose()

passed = 0
if sum.get(0 0) == 6 { passed = passed + 1 }
if product.get(0 0) == 19 { passed = passed + 1 }
if transposed.get(0 1) == 3 { passed = passed + 1 }
if transposed.get(1 0) == 2 { passed = passed + 1 }

result = "OK:" + toString(passed)
