// 场景测试 - rotated array：旋转数组最小值查找
// EXPECT: "OK:4"
fn findMin(nums) {
    left = 0
    right = len(nums) - 1
    
    while left < right {
        mid = floor((left + right) / 2)
        
        if nums[mid] > nums[right] {
            left = mid + 1
        } else {
            if nums[mid] < nums[right] {
                right = mid
            } else {
                right = right - 1
            }
        }
    }
    
    return nums[left]
}

fn findMin2(nums) {
    left = 0
    right = len(nums) - 1
    
    while left < right {
        mid = floor((left + right) / 2)
        
        if nums[mid] > nums[right] {
            left = mid + 1
        } else {
            right = mid
        }
    }
    
    return nums[left]
}

fn search2(nums target) {
    left = 0
    right = len(nums) - 1
    
    while left <= right {
        mid = floor((left + right) / 2)
        
        if nums[mid] == target { return true }
        
        if nums[left] == nums[mid] && nums[mid] == nums[right] {
            left = left + 1
            right = right - 1
        } else {
            if nums[left] <= nums[mid] {
                if target >= nums[left] && target < nums[mid] {
                    right = mid - 1
                } else {
                    left = mid + 1
                }
            } else {
                if target > nums[mid] && target <= nums[right] {
                    left = mid + 1
                } else {
                    right = mid - 1
                }
            }
        }
    }
    
    return false
}

passed = 0

if findMin([3 4 5 1 2]) == 1 { passed = passed + 1 }
if findMin2([4 5 6 7 0 1 2]) == 0 { passed = passed + 1 }
if search2([2 5 6 0 0 1 2] 0) { passed = passed + 1 }
if search2([2 5 6 0 0 1 2] 3) == false { passed = passed + 1 }

result = "OK:" + toString(passed)
