// 场景测试 - sliding window：滑动窗口算法（定长/变长）
// EXPECT: "OK:4"
fn slidingWindowMax(arr k) {
    result = []
    n = len(arr)
    
    if n == 0 || k == 0 { return result }
    
    i = 0
    while i <= n - k {
        maxVal = arr[i]
        j = i
        while j < i + k {
            if arr[j] > maxVal { maxVal = arr[j] }
            j = j + 1
        }
        push(result maxVal)
        i = i + 1
    }
    
    return result
}

fn slidingWindowSum(arr k) {
    result = []
    n = len(arr)
    
    if n == 0 || k == 0 { return result }
    
    windowSum = 0
    i = 0
    while i < k {
        windowSum = windowSum + arr[i]
        i = i + 1
    }
    push(result windowSum)
    
    i = k
    while i < n {
        windowSum = windowSum - arr[i - k] + arr[i]
        push(result windowSum)
        i = i + 1
    }
    
    return result
}

fn twoSum(nums target) {
    seen = {}
    i = 0
    while i < len(nums) {
        complement = target - nums[i]
        if seen[complement] != null {
            return [seen[complement] i]
        }
        seen[nums[i]] = i
        i = i + 1
    }
    return []
}

arr = [1 3 -1 -3 5 3 6 7]

passed = 0

maxs = slidingWindowMax(arr 3)
if maxs[0] == 3 && maxs[1] == 3 && maxs[2] == 5 { passed = passed + 1 }

sums = slidingWindowSum([1 2 3 4 5] 3)
if sums[0] == 6 && sums[1] == 9 && sums[2] == 12 { passed = passed + 1 }

pair = twoSum([2 7 11 15] 9)
if pair[0] == 0 && pair[1] == 1 { passed = passed + 1 }

pair2 = twoSum([3 2 4] 6)
if pair2[0] == 1 && pair2[1] == 2 { passed = passed + 1 }

result = "OK:" + toString(passed)
