// 场景测试 - hell suite（地狱级综合）：地狱难度第 1 套综合挑战
// EXPECT: "OK:19"

fn fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

fn gcd(a b) {
    x = a
    y = b
    while y != 0 {
        t = x % y
        x = y
        y = t
    }
    return x
}

fn sumArray(arr) {
    i = 0
    s = 0
    while i < len(arr) {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

passed = 0

arr = [1 2 3 4 5]
if len(arr) == 5 { passed = passed + 1 }
if sumArray(arr) == 15 { passed = passed + 1 }

obj = { a: 1 b: 2 }
obj.c = 3
if obj.a + obj.b + obj.c == 6 { passed = passed + 1 }

if fib(8) == 21 { passed = passed + 1 }
if gcd(84 18) == 6 { passed = passed + 1 }

s = "seed"
if upper(s) == "SEED" { passed = passed + 1 }
if lower("VM") == "vm" { passed = passed + 1 }
if substring("abcdef" 2 5) == "cde" { passed = passed + 1 }

nums = [3 1 4 1 5]
if indexOf(nums 4) == 2 { passed = passed + 1 }
push(nums 9)
if len(nums) == 6 { passed = passed + 1 }
if pop(nums) == 9 { passed = passed + 1 }

counter = 0
for x in [1 2 3 4 5] {
    if x == 3 { continue }
    counter = counter + x
}
if counter == 12 { passed = passed + 1 }

i = 0
acc = 1
while i < 6 {
    acc = acc * 2
    i = i + 1
}
if acc == 64 { passed = passed + 1 }

fn makeAdder(n) {
    fn add(m) {
        return n + m
    }
    return add
}

add7 = makeAdder(7)
if add7(5) == 12 { passed = passed + 1 }

tbl = {}
tbl["k1"] = 10
tbl["k2"] = 20
if tbl["k1"] + tbl["k2"] == 30 { passed = passed + 1 }

parts = split("a-b-c" "-")
if len(parts) == 3 { passed = passed + 1 }
if join(parts ":") == "a:b:c" { passed = passed + 1 }

if toInt("42") == 42 { passed = passed + 1 }
if toString(true) == "true" { passed = passed + 1 }

result = "OK:" + toString(passed)
