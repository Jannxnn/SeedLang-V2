// 场景测试 - peak finding：峰值查找算法
// EXPECT: "OK:4"
fn findPeakElement(nums) {
    left = 0
    right = len(nums) - 1
    
    while left < right {
        mid = floor((left + right) / 2)
        
        if nums[mid] < nums[mid + 1] {
            left = mid + 1
        } else {
            right = mid
        }
    }
    
    return left
}

fn findPeakGrid(mat) {
    rows = len(mat)
    cols = len(mat[0])
    
    low = 0
    high = cols - 1
    
    while low <= high {
        mid = floor((low + high) / 2)
        
        maxRow = 0
        i = 1
        while i < rows {
            if mat[i][mid] > mat[maxRow][mid] {
                maxRow = i
            }
            i = i + 1
        }
        
        left = -1
        if mid > 0 { left = mat[maxRow][mid - 1] }
        
        right = -1
        if mid < cols - 1 { right = mat[maxRow][mid + 1] }
        
        if mat[maxRow][mid] > left && mat[maxRow][mid] > right {
            return [maxRow mid]
        }
        
        if right > mat[maxRow][mid] {
            low = mid + 1
        } else {
            high = mid - 1
        }
    }
    
    return [-1 -1]
}

fn peakIndexInMountainArray(arr) {
    left = 0
    right = len(arr) - 1
    
    while left < right {
        mid = floor((left + right) / 2)
        
        if arr[mid] < arr[mid + 1] {
            left = mid + 1
        } else {
            right = mid
        }
    }
    
    return left
}

passed = 0

if findPeakElement([1 2 3 1]) == 2 { passed = passed + 1 }

if peakIndexInMountainArray([0 1 0]) == 1 { passed = passed + 1 }

if peakIndexInMountainArray([0 2 1 0]) == 1 { passed = passed + 1 }

if findPeakElement([1 2 1 3 5 6 4]) >= 1 { passed = passed + 1 }

result = "OK:" + toString(passed)
