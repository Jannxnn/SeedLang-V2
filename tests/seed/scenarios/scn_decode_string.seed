// 场景测试 - decode string：编码字符串解码（k[encoded] 格式）
// EXPECT: "OK:4"
fn decodeString(s) {
    stack = []
    currentNum = 0
    currentStr = ""
    
    i = 0
    while i < len(s) {
        c = charAt(s i)
        
        if c >= "0" && c <= "9" {
            currentNum = currentNum * 10 + (c - 48)
        } else {
            if c == "[" {
                push(stack currentStr)
                push(stack currentNum)
                currentStr = ""
                currentNum = 0
            } else {
                if c == "]" {
                    num = stack[len(stack) - 1]
                    stack = slice(stack 0 len(stack) - 1)
                    prevStr = stack[len(stack) - 1]
                    stack = slice(stack 0 len(stack) - 1)
                    
                    temp = ""
                    j = 0
                    while j < num {
                        temp = temp + currentStr
                        j = j + 1
                    }
                    currentStr = prevStr + temp
                } else {
                    currentStr = currentStr + c
                }
            }
        }
        i = i + 1
    }
    
    return currentStr
}

fn countOfAtoms(formula) {
    i = 0
    n = len(formula)
    
    fn parse() {
        count = {}
        
        while i < n && charAt(formula i) != ")" {
            if charAt(formula i) == "(" {
                i = i + 1
                inner = parse()
                i = i + 1
                
                num = 0
                while i < n && charAt(formula i) >= "0" && charAt(formula i) <= "9" {
                    num = num * 10 + (charAt(formula i) - 48)
                    i = i + 1
                }
                if num == 0 { num = 1 }
                
                for key in keys(inner) {
                    if count[key] == null { count[key] = 0 }
                    count[key] = count[key] + inner[key] * num
                }
            } else {
                name = charAt(formula i)
                i = i + 1
                
                while i < n && charAt(formula i) >= "a" && charAt(formula i) <= "z" {
                    name = name + charAt(formula i)
                    i = i + 1
                }
                
                num = 0
                while i < n && charAt(formula i) >= "0" && charAt(formula i) <= "9" {
                    num = num * 10 + (charAt(formula i) - 48)
                    i = i + 1
                }
                if num == 0 { num = 1 }
                
                if count[name] == null { count[name] = 0 }
                count[name] = count[name] + num
            }
        }
        
        return count
    }
    
    return parse()
}

passed = 0

if decodeString("3[a]2[bc]") == "aaabcbc" { passed = passed + 1 }
if decodeString("3[a2[c]]") == "accaccacc" { passed = passed + 1 }
if decodeString("2[abc]3[cd]ef") == "abcabccdcdcdef" { passed = passed + 1 }

atoms = countOfAtoms("H2O")
if atoms["H"] == 2 && atoms["O"] == 1 { passed = passed + 1 }

result = "OK:" + toString(passed)
