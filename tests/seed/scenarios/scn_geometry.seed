// 场景测试 - geometry：几何计算（凸包/最大点数等）
// EXPECT: "OK:4"
fn maxPoints(points) {
    if len(points) <= 2 { return len(points) }
    
    maxCount = 0
    
    i = 0
    while i < len(points) {
        slopes = {}
        same = 1
        currentMax = 0
        
        j = i + 1
        while j < len(points) {
            dx = points[j][0] - points[i][0]
            dy = points[j][1] - points[i][1]
            
            if dx == 0 && dy == 0 {
                same = same + 1
            } else {
                if dx == 0 {
                    key = "inf"
                } else {
                    if dy == 0 {
                        key = "0"
                    } else {
                        gcd = abs(dy)
                        temp = abs(dx)
                        while temp != 0 {
                            t = gcd % temp
                            gcd = temp
                            temp = t
                        }
                        key = toString(dy / gcd) + "/" + toString(dx / gcd)
                    }
                }
                
                if slopes[key] == null { slopes[key] = 0 }
                slopes[key] = slopes[key] + 1
                
                if slopes[key] > currentMax { currentMax = slopes[key] }
            }
            j = j + 1
        }
        
        if currentMax + same > maxCount { maxCount = currentMax + same }
        i = i + 1
    }
    
    return maxCount
}

fn computeArea(ax1 ay1 ax2 ay2 bx1 by1 bx2 by2) {
    areaA = (ax2 - ax1) * (ay2 - ay1)
    areaB = (bx2 - bx1) * (by2 - by1)
    
    overlapWidth = max(0 min(ax2 bx2) - max(ax1 bx1))
    overlapHeight = max(0 min(ay2 by2) - max(ay1 by1))
    overlapArea = overlapWidth * overlapHeight
    
    return areaA + areaB - overlapArea
}

fn isRectangleOverlap(rec1 rec2) {
    return rec1[0] < rec2[2] && rec1[2] > rec2[0] && 
           rec1[1] < rec2[3] && rec1[3] > rec2[1]
}

passed = 0

if maxPoints([[1 1] [2 2] [3 3]]) == 3 { passed = passed + 1 }

if computeArea(-2 -2 2 2 -2 -2 2 2) == 16 { passed = passed + 1 }

if isRectangleOverlap([0 0 2 2] [1 1 3 3]) { passed = passed + 1 }

if isRectangleOverlap([0 0 1 1] [1 0 2 1]) == false { passed = passed + 1 }

result = "OK:" + toString(passed)
