// 场景测试 - monotonic stack：单调栈（下一个更大元素等）
// EXPECT: "OK:4"
fn nextGreaterElements(nums) {
    n = len(nums)
    result = []
    
    i = 0
    while i < n {
        push(result 0-1)
        i = i + 1
    }
    
    stack = []
    
    i = 0
    while i < 2 * n {
        idx = i % n
        
        while len(stack) > 0 && nums[idx] > nums[stack[len(stack) - 1]] {
            result[stack[len(stack) - 1]] = nums[idx]
            stack = slice(stack 0 len(stack) - 1)
        }
        
        if i < n {
            push(stack idx)
        }
        
        i = i + 1
    }
    
    return result
}

fn dailyTemperatures(temperatures) {
    n = len(temperatures)
    result = []
    
    i = 0
    while i < n {
        push(result 0)
        i = i + 1
    }
    
    stack = []
    
    i = 0
    while i < n {
        while len(stack) > 0 && temperatures[i] > temperatures[stack[len(stack) - 1]] {
            idx = stack[len(stack) - 1]
            stack = slice(stack 0 len(stack) - 1)
            result[idx] = i - idx
        }
        
        push(stack i)
        i = i + 1
    }
    
    return result
}

fn nextGreaterElement(nums1 nums2) {
    nextGreater = {}
    stack = []
    
    for n in nums2 {
        while len(stack) > 0 && n > stack[len(stack) - 1] {
            nextGreater[stack[len(stack) - 1]] = n
            stack = slice(stack 0 len(stack) - 1)
        }
        push(stack n)
    }
    
    while len(stack) > 0 {
        nextGreater[stack[len(stack) - 1]] = -1
        stack = slice(stack 0 len(stack) - 1)
    }
    
    result = []
    for n in nums1 {
        push(result nextGreater[n])
    }
    
    return result
}

passed = 0

result1 = nextGreaterElements([1 2 1])
if result1[0] == 2 && result1[1] == -1 && result1[2] == 2 { passed = passed + 1 }

temps = dailyTemperatures([73 74 75 71 69 72 76 73])
if temps[0] == 1 && temps[1] == 1 && temps[2] == 4 { passed = passed + 1 }

result2 = nextGreaterElement([4 1 2] [1 3 4 2])
if result2[0] == -1 && result2[1] == 3 && result2[2] == -1 { passed = passed + 1 }

result3 = nextGreaterElements([5 4 3 2 1])
if result3[0] == -1 { passed = passed + 1 }

result = "OK:" + toString(passed)
