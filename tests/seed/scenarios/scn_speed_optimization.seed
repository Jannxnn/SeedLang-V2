// EXPECT: "OK:4"
fn minEatingSpeed(piles h) {
    left = 1
    right = 0
    
    for p in piles {
        if p > right { right = p }
    }
    
    while left < right {
        mid = floor((left + right) / 2)
        
        hours = 0
        for p in piles {
            hours = hours + floor((p + mid - 1) / mid)
        }
        
        if hours <= h {
            right = mid
        } else {
            left = mid + 1
        }
    }
    
    return left
}

fn smallestDivisor(nums threshold) {
    left = 1
    right = 0
    
    for n in nums {
        if n > right { right = n }
    }
    
    while left < right {
        mid = floor((left + right) / 2)
        
        sum = 0
        for n in nums {
            sum = sum + floor((n + mid - 1) / mid)
        }
        
        if sum <= threshold {
            right = mid
        } else {
            left = mid + 1
        }
    }
    
    return left
}

fn minSpeedOnTime(dist hour) {
    left = 1
    right = 10000000
    
    while left < right {
        mid = floor((left + right) / 2)
        
        time = 0
        i = 0
        while i < len(dist) - 1 {
            time = time + floor((dist[i] + mid - 1) / mid)
            i = i + 1
        }
        
        time = time + dist[len(dist) - 1] / mid
        
        if time <= hour {
            right = mid
        } else {
            left = mid + 1
        }
    }
    
    if left == 10000000 { return -1 }
    return left
}

passed = 0

if minEatingSpeed([3 6 7 11] 8) == 4 { passed = passed + 1 }
if smallestDivisor([1 2 5 9] 6) == 5 { passed = passed + 1 }
if minSpeedOnTime([1 3 2] 6) == 1 { passed = passed + 1 }
if minEatingSpeed([30 11 23 4 20] 5) == 30 { passed = passed + 1 }

result = "OK:" + toString(passed)
