// EXPECT: "23040|48|10"
i = 0
sum = 0
throws = 0
finals = 0
while i < 240 {
    try {
        if i - floor(i / 5) * 5 == 0 {
            throw "X"
        }
        sum = sum + i
    } catch(e) {
        throws = throws + 1
    } finally {
        if i - floor(i / 24) * 24 == 0 {
            finals = finals + 1
        }
    }
    i = i + 1
}
result = toString(sum) + "|" + toString(throws) + "|" + toString(finals)
