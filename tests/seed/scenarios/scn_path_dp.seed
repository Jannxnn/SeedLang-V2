// 场景测试 - path dp：路径解码等动态规划路径问题
// EXPECT: "OK:4"
fn numDecodings(s) {
    if len(s) == 0 || charAt(s 0) == "0" { return 0 }
    
    n = len(s)
    dp = []
    i = 0
    while i <= n {
        push(dp 0)
        i = i + 1
    }
    dp[0] = 1
    dp[1] = 1
    
    i = 2
    while i <= n {
        oneDigit = toInt(charAt(s i - 1))
        if oneDigit >= 1 && oneDigit <= 9 {
            dp[i] = dp[i] + dp[i - 1]
        }
        
        twoDigit = toInt(charAt(s i - 2)) * 10 + oneDigit
        if twoDigit >= 10 && twoDigit <= 26 {
            dp[i] = dp[i] + dp[i - 2]
        }
        i = i + 1
    }
    
    return dp[n]
}

fn climbStairs(n) {
    if n <= 2 { return n }
    
    prev2 = 1
    prev1 = 2
    
    i = 3
    while i <= n {
        current = prev1 + prev2
        prev2 = prev1
        prev1 = current
        i = i + 1
    }
    
    return prev1
}

fn uniquePaths(m n) {
    dp = []
    i = 0
    while i < m {
        row = []
        j = 0
        while j < n {
            push(row 1)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    
    i = 1
    while i < m {
        j = 1
        while j < n {
            dp[i][j] = dp[i - 1][j] + dp[i][j - 1]
            j = j + 1
        }
        i = i + 1
    }
    
    return dp[m - 1][n - 1]
}

fn minPathSum(grid) {
    m = len(grid)
    n = len(grid[0])
    
    i = 1
    while i < m {
        grid[i][0] = grid[i][0] + grid[i - 1][0]
        i = i + 1
    }
    
    j = 1
    while j < n {
        grid[0][j] = grid[0][j] + grid[0][j - 1]
        j = j + 1
    }
    
    i = 1
    while i < m {
        j = 1
        while j < n {
            grid[i][j] = grid[i][j] + min(grid[i - 1][j] grid[i][j - 1])
            j = j + 1
        }
        i = i + 1
    }
    
    return grid[m - 1][n - 1]
}

passed = 0

if numDecodings("12") == 2 { passed = passed + 1 }
if climbStairs(5) == 8 { passed = passed + 1 }
if uniquePaths(3 7) == 28 { passed = passed + 1 }
if minPathSum([[1 3 1] [1 5 1] [4 2 1]]) == 7 { passed = passed + 1 }

result = "OK:" + toString(passed)
