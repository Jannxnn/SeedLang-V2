// 场景测试 - scheduling：任务调度（冷却间隔/优先级）
// EXPECT: "OK:4"
fn scheduleTasks(tasks cooldown) {
    schedule = []
    lastPos = {}
    
    for task in tasks {
        if lastPos[task] != null {
            lastTime = lastPos[task]
            requiredWait = lastTime + cooldown + 1
            while len(schedule) < requiredWait {
                push(schedule "idle")
            }
        }
        push(schedule task)
        lastPos[task] = len(schedule) - 1
    }
    
    return len(schedule)
}

fn meetingRooms(intervals) {
    if len(intervals) == 0 { return 0 }
    
    starts = []
    ends = []
    
    for interval in intervals {
        push(starts interval[0])
        push(ends interval[1])
    }
    
    starts = sort(starts)
    ends = sort(ends)
    
    rooms = 0
    endIdx = 0
    
    for start in starts {
        if start < ends[endIdx] {
            rooms = rooms + 1
        } else {
            endIdx = endIdx + 1
        }
    }
    
    return rooms
}

fn mergeIntervals(intervals) {
    if len(intervals) == 0 { return [] }
    
    sorted = sort(intervals)
    merged = [sorted[0]]
    
    i = 1
    while i < len(sorted) {
        current = sorted[i]
        last = merged[len(merged) - 1]
        
        if current[0] <= last[1] {
            if current[1] > last[1] {
                last[1] = current[1]
            }
        } else {
            push(merged current)
        }
        i = i + 1
    }
    
    return merged
}

passed = 0

if scheduleTasks(["A" "A" "B"] 2) == 5 { passed = passed + 1 }

rooms = meetingRooms([[0 30] [5 10] [15 20]])
if rooms == 2 { passed = passed + 1 }

merged = mergeIntervals([[1 3] [2 6] [8 10] [15 18]])
if len(merged) == 3 { passed = passed + 1 }

if merged[0][1] == 6 { passed = passed + 1 }

result = "OK:" + toString(passed)
