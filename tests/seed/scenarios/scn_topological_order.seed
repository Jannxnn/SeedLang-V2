// 场景测试 - topological order：拓扑排序与外星字典顺序
// EXPECT: "OK:4"
fn alienOrder(words) {
    graph = {}
    inDegree = {}
    
    for word in words {
        chars = split(word "")
        for c in chars {
            if graph[c] == null {
                graph[c] = []
                inDegree[c] = 0
            }
        }
    }
    
    i = 0
    while i < len(words) - 1 {
        w1 = words[i]
        w2 = words[i + 1]
        
        minLen = min(len(w1) len(w2))
        j = 0
        found = false
        
        while j < minLen && found == false {
            c1 = charAt(w1 j)
            c2 = charAt(w2 j)
            
            if c1 != c2 {
                push(graph[c1] c2)
                inDegree[c2] = inDegree[c2] + 1
                found = true
            }
            j = j + 1
        }
        
        if found == false && len(w1) > len(w2) {
            return ""
        }
        
        i = i + 1
    }
    
    queue = []
    for c in keys(inDegree) {
        if inDegree[c] == 0 {
            push(queue c)
        }
    }
    
    result = ""
    while len(queue) > 0 {
        c = queue[0]
        queue = slice(queue 1 len(queue))
        result = result + c
        
        for neighbor in graph[c] {
            inDegree[neighbor] = inDegree[neighbor] - 1
            if inDegree[neighbor] == 0 {
                push(queue neighbor)
            }
        }
    }
    
    if len(result) == len(keys(graph)) { return result }
    return ""
}

fn sequenceReconstruction(org seqs) {
    graph = {}
    inDegree = {}
    
    for n in org {
        graph[n] = []
        inDegree[n] = 0
    }
    
    for seq in seqs {
        i = 0
        while i < len(seq) - 1 {
            push(graph[seq[i]] seq[i + 1])
            inDegree[seq[i + 1]] = inDegree[seq[i + 1]] + 1
            i = i + 1
        }
    }
    
    queue = []
    for n in keys(inDegree) {
        if inDegree[n] == 0 {
            push(queue n)
        }
    }
    
    result = []
    while len(queue) > 0 {
        if len(queue) > 1 { return false }
        
        current = queue[0]
        queue = slice(queue 1 len(queue))
        push(result current)
        
        for neighbor in graph[current] {
            inDegree[neighbor] = inDegree[neighbor] - 1
            if inDegree[neighbor] == 0 {
                push(queue neighbor)
            }
        }
    }
    
    if len(result) != len(org) { return false }
    
    i = 0
    while i < len(result) {
        if result[i] != org[i] { return false }
        i = i + 1
    }
    
    return true
}

passed = 0

order1 = alienOrder(["wrt" "wrf" "er" "ett" "rftt"])
if len(order1) == 5 { passed = passed + 1 }

order2 = alienOrder(["z" "x"])
if order2 == "zx" { passed = passed + 1 }

if sequenceReconstruction([1 2 3] [[1 2] [2 3]]) { passed = passed + 1 }

if sequenceReconstruction([1 2 3] [[1 2] [1 3]]) == false { passed = passed + 1 }

result = "OK:" + toString(passed)
