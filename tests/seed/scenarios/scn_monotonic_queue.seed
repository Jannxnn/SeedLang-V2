// 场景测试 - monotonic queue：单调队列（滑动窗口最大值）
// EXPECT: "OK:4"
fn maxSlidingWindow(nums k) {
    if len(nums) == 0 || k == 0 { return [] }
    
    result = []
    deque = []
    
    i = 0
    while i < len(nums) {
        while len(deque) > 0 && deque[0] < i - k + 1 {
            deque = slice(deque 1 len(deque))
        }
        
        while len(deque) > 0 && nums[deque[len(deque) - 1]] < nums[i] {
            deque = slice(deque 0 len(deque) - 1)
        }
        
        push(deque i)
        
        if i >= k - 1 {
            push(result nums[deque[0]])
        }
        
        i = i + 1
    }
    
    return result
}

fn maxResult(nums k) {
    n = len(nums)
    dp = []
    i = 0
    while i < n {
        push(dp 0-999999)
        i = i + 1
    }
    dp[0] = nums[0]
    
    deque = [0]
    
    i = 1
    while i < n {
        while len(deque) > 0 && deque[0] < i - k {
            deque = slice(deque 1 len(deque))
        }
        
        dp[i] = dp[deque[0]] + nums[i]
        
        while len(deque) > 0 && dp[i] >= dp[deque[len(deque) - 1]] {
            deque = slice(deque 0 len(deque) - 1)
        }
        
        push(deque i)
        i = i + 1
    }
    
    return dp[n - 1]
}

fn constrainedSubsetSum(nums k) {
    n = len(nums)
    dp = []
    for n in nums { push(dp n) }
    
    deque = [0]
    maxSum = dp[0]
    
    i = 1
    while i < n {
        while len(deque) > 0 && deque[0] < i - k {
            deque = slice(deque 1 len(deque))
        }
        
        if dp[deque[0]] > 0 {
            dp[i] = dp[i] + dp[deque[0]]
        }
        
        if dp[i] > maxSum { maxSum = dp[i] }
        
        while len(deque) > 0 && dp[i] >= dp[deque[len(deque) - 1]] {
            deque = slice(deque 0 len(deque) - 1)
        }
        
        push(deque i)
        i = i + 1
    }
    
    return maxSum
}

passed = 0

result1 = maxSlidingWindow([1 3 -1 -3 5 3 6 7] 3)
if result1[0] == 3 && result1[1] == 3 && result1[2] == 5 { passed = passed + 1 }

if maxResult([1 -1 -2 4 -7 3] 2) == 7 { passed = passed + 1 }

if constrainedSubsetSum([10 2 -10 5 20] 2) == 37 { passed = passed + 1 }

result2 = maxSlidingWindow([1] 1)
if result2[0] == 1 { passed = passed + 1 }

result = "OK:" + toString(passed)
