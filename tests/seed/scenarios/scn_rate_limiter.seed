// 场景测试 - rate limiter：限流器（令牌桶/滑动窗口）
// EXPECT: "OK:4"
class RateLimiter {
    init(maxRequests windowMs) {
        this.maxRequests = maxRequests
        this.windowMs = windowMs
        this.requests = {}
    }
    
    check(key) {
        now = timestamp()
        
        if this.requests[key] == null {
            this.requests[key] = []
        }
        
        validRequests = []
        for ts in this.requests[key] {
            if now - ts < this.windowMs {
                push(validRequests ts)
            }
        }
        this.requests[key] = validRequests
        
        if len(validRequests) < this.maxRequests {
            push(this.requests[key] now)
            return true
        }
        return false
    }
    
    reset(key) {
        this.requests[key] = []
    }
}

class CircuitBreaker {
    init(failureThreshold resetTimeout) {
        this.failureThreshold = failureThreshold
        this.resetTimeout = resetTimeout
        this.failures = 0
        this.state = "CLOSED"
        this.lastFailureTime = 0
    }
    
    canExecute() {
        if this.state == "CLOSED" { return true }
        if this.state == "OPEN" {
            if timestamp() - this.lastFailureTime >= this.resetTimeout {
                this.state = "HALF_OPEN"
                return true
            }
            return false
        }
        return true
    }
    
    recordSuccess() {
        this.failures = 0
        this.state = "CLOSED"
    }
    
    recordFailure() {
        this.failures = this.failures + 1
        this.lastFailureTime = timestamp()
        if this.failures >= this.failureThreshold {
            this.state = "OPEN"
        }
    }
}

limiter = RateLimiter(3 1000)
breaker = CircuitBreaker(2 1000)

passed = 0
if limiter.check("user1") { passed = passed + 1 }
if limiter.check("user1") { passed = passed + 1 }
if limiter.check("user1") { passed = passed + 1 }
if limiter.check("user1") == false { passed = passed + 1 }

result = "OK:" + toString(passed)
