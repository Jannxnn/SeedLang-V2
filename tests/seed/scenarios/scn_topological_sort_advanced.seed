// 场景测试 - topological sort advanced：高级拓扑排序应用
// EXPECT: "OK:4"
fn canFinish(numCourses prerequisites) {
    graph = {}
    inDegree = {}
    
    i = 0
    while i < numCourses {
        graph[i] = []
        inDegree[i] = 0
        i = i + 1
    }
    
    for pre in prerequisites {
        push(graph[pre[1]] pre[0])
        inDegree[pre[0]] = inDegree[pre[0]] + 1
    }
    
    queue = []
    for i in keys(inDegree) {
        if inDegree[i] == 0 {
            push(queue i)
        }
    }
    
    count = 0
    while len(queue) > 0 {
        current = queue[0]
        queue = slice(queue 1 len(queue))
        count = count + 1
        
        for neighbor in graph[current] {
            inDegree[neighbor] = inDegree[neighbor] - 1
            if inDegree[neighbor] == 0 {
                push(queue neighbor)
            }
        }
    }
    
    return count == numCourses
}

fn findOrder(numCourses prerequisites) {
    graph = {}
    inDegree = {}
    
    i = 0
    while i < numCourses {
        graph[i] = []
        inDegree[i] = 0
        i = i + 1
    }
    
    for pre in prerequisites {
        push(graph[pre[1]] pre[0])
        inDegree[pre[0]] = inDegree[pre[0]] + 1
    }
    
    queue = []
    for i in keys(inDegree) {
        if inDegree[i] == 0 {
            push(queue i)
        }
    }
    
    result = []
    while len(queue) > 0 {
        current = queue[0]
        queue = slice(queue 1 len(queue))
        push(result current)
        
        for neighbor in graph[current] {
            inDegree[neighbor] = inDegree[neighbor] - 1
            if inDegree[neighbor] == 0 {
                push(queue neighbor)
            }
        }
    }
    
    if len(result) == numCourses { return result }
    return []
}

passed = 0

if canFinish(2 [[1 0]]) { passed = passed + 1 }
if canFinish(2 [[1 0] [0 1]]) == false { passed = passed + 1 }

order = findOrder(4 [[1 0] [2 0] [3 1] [3 2]])
if len(order) == 4 { passed = passed + 1 }

order2 = findOrder(1 [])
if order2[0] == 0 { passed = passed + 1 }

result = "OK:" + toString(passed)
