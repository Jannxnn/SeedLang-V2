trieSearch2 = trieSearch("apple")
trieSearch3 = trieSearch("appl")
triePrefix = trieStartsWith("app")

fn slidingWindowMax(arr k) {
    result = []
    deque = []
    
    i = 0
    while i < len(arr) {
        while len(deque) > 0 && deque[0] < i - k + 1 {
            deque = slice(deque 1 len(deque))
        }
        
        while len(deque) > 0 && arr[deque[len(deque) - 1]] < arr[i] {
            deque = slice(deque 0 len(deque) - 1)
        }
        
        push(deque i)
        
        if i >= k - 1 {
            push(result arr[deque[0]])
        }
        
        i = i + 1
    }
    
    return result
}

windowMax = slidingWindowMax([1 3 0-1 0-3 5 3 6 7] 3)
windowMaxFirst = windowMax[0]

ufParent = []
ufRank = []

fn ufInit(n) {
    i = 0
    while i < n {
        push(ufParent i)
        push(ufRank 0)
        i = i + 1
    }
}

fn ufFind(x) {
    if ufParent[x] != x {
        ufParent[x] = ufFind(ufParent[x])
    }
    return ufParent[x]
}

fn ufUnion(x y) {
    px = ufFind(x)
    py = ufFind(y)
    
    if px == py { return false }
    
    if ufRank[px] < ufRank[py] {
        ufParent[px] = py
    } else {
        if ufRank[px] > ufRank[py] {
            ufParent[py] = px
        } else {
            ufParent[py] = px
            ufRank[px] = ufRank[px] + 1
        }
    }
    return true
}

ufInit(5)
ufUnion(0 1)
ufUnion(2 3)
ufUnion(0 2)
ufFind1 = ufFind(1)
ufFind2 = ufFind(3)

fn nextGreaterElements(arr) {
    n = len(arr)
    result = []
    
    i = 0
    while i < n {
        push(result 0-1)
        i = i + 1
    }
    
    stack = []
    
    i = 0
    while i < 2 * n {
        idx = i % n
        
        while len(stack) > 0 && arr[idx] > arr[stack[len(stack) - 1]] {
            result[stack[len(stack) - 1]] = arr[idx]
            stack = slice(stack 0 len(stack) - 1)
        }
        
        if i < n {
            push(stack idx)
        }
        
        i = i + 1
    }
    
    return result
}

nextGreater = nextGreaterElements([1 2 1])
nextGreater0 = nextGreater[0]

diffArr = []

fn diffInit(n) {
    i = 0
    while i < n {
        push(diffArr 0)
        i = i + 1
    }
}

fn diffUpdate(left right val) {
    diffArr[left] = diffArr[left] + val
    if right + 1 < len(diffArr) {
        diffArr[right + 1] = diffArr[right + 1] - val
    }
}

fn diffResult() {
    arr = []
    sum = 0
    for d in diffArr {
        sum = sum + d
        push(arr sum)
    }
    return arr
}

diffInit(5)
diffUpdate(1 3 2)
diffUpdate(2 4 3)
diffRes = diffResult()
