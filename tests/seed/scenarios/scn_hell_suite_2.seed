fn deepTryCatch(depth) {
    result = 0
    try {
        try {
            try {
                try {
                    try {
                        if depth > 0 { throw "deep" }
                        result = 100
                    } catch(e1) {
                        result = result + 1
                        throw "level4"
                    }
                } catch(e2) {
                    result = result + 2
                    throw "level3"
                }
            } catch(e3) {
                result = result + 4
                throw "level2"
            }
        } catch(e4) {
            result = result + 8
            throw "level1"
        }
    } catch(e5) {
        result = result + 16
    }
    return result
}

nestedException = deepTryCatch(1)

fn complexControlFlow(n) {
    sum = 0
    i = 0
    
    while i < n {
        j = 0
        while j < n {
            k = 0
            while k < n {
                if i == j && j == k {
                    sum = sum + 1
                } else {
                    if i + j + k == n - 1 {
                        sum = sum + 2
                    } else {
                        if (i + j + k) % 3 == 0 {
                            sum = sum + 3
                        }
                    }
                }
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    
    return sum
}

controlFlowResult = complexControlFlow(5)

fn makeCounter(start step) {
    count = start
    return () => {
        current = count
        count = count + step
        return current
    }
}

