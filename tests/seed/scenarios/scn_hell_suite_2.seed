fn transformData(data) {
    result = {}
    
    for item in data {
        category = item.category
        if result[category] == null {
            result[category] = { total: 0 items: [] }
        }
        result[category].total = result[category].total + item.value
        push(result[category].items item.name)
    }
    
    return result
}

