    { name: "a" category: "x" value: 1 }
    { name: "b" category: "y" value: 2 }
    { name: "c" category: "x" value: 3 }
    { name: "d" category: "y" value: 4 }
    { name: "e" category: "x" value: 5 }
]

transformed = transformData(transformInput)
transformX = transformed.x.total

fn parseExpression(tokens) {
    pos = 0
    
    fn peek() {
        if pos < len(tokens) { return tokens[pos] }
        return null
    }
    
    fn consume() {
        token = peek()
        pos = pos + 1
        return token
    }
    
    fn parseTerm() {
        left = parseFactor()
        
        while peek() == "*" || peek() == "/" {
            op = consume()
            right = parseFactor()
            if op == "*" { left = left * right }
            if op == "/" { left = left / right }
        }
        
        return left
    }
    
    fn parseFactor() {
        token = consume()
        if type(token) == "number" { return token }
        if token == "(" {
            result = parseExpr()
            consume()
            return result
        }
        return 0
    }
    
    fn parseExpr() {
        left = parseTerm()
        
        while peek() == "+" || peek() == "-" {
            op = consume()
            right = parseTerm()
            if op == "+" { left = left + right }
            if op == "-" { left = left - right }
        }
        
        return left
    }
    
    return parseExpr()
}

parseResult = parseExpression([2 "+" 3 "*" 4 "-" 1])

fn bitManipulation(n) {
    result = 0
    
    i = 0
    while i < 32 {
        if (n & (1 << i)) != 0 {
            result = result + 1
        }
        i = i + 1
    }
    
    return result
}

bitCount = bitManipulation(255)

fn encode(str) {
    result = ""
    i = 0
    while i < len(str) {
        c = charAt(str i)
        code = 0
        if c == "A" { code = 27 }
        if c == "b" { code = 2 }
        if c == "1" { code = 54 }
        result = result + toString(code) + "-"
        i = i + 1
    }
    return result
}

encoded = encode("Ab1")
encodedLen = len(encoded)

fn stateTransitions(events) {
    states = {
        S0: { onA: "S1" onB: "S2" }
        S1: { onA: "S0" onB: "S3" }
        S2: { onA: "S3" onB: "S0" }
        S3: { onA: "S2" onB: "S1" }
    }
    
    current = "S0"
    count = 0
    
    for event in events {
        next = states[current][event]
        if next != null {
            current = next
            count = count + 1
        }
    }
    
    return { final: current transitions: count }
}

stateResult2 = stateTransitions(["onA" "onB" "onA" "onB" "onA"])

fn multiDimArray(n) {
    arr = []
    
    i = 0
    while i < n {
        row = []
        j = 0
        while j < n {
            cell = []
            k = 0
            while k < n {
                push(cell i * n * n + j * n + k)
                k = k + 1
            }
            push(row cell)
            j = j + 1
        }
        push(arr row)
        i = i + 1
    }
    
    sum = 0
    i = 0
    while i < n {
        j = 0
        while j < n {
            k = 0
            while k < n {
                sum = sum + arr[i][j][k]
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    
    return sum
}

multiDimSum = multiDimArray(3)

fn curry(func arity) {
    fn curried(args) {
        return (x) => {
            newArgs = []
            for a in args { push(newArgs a) }
            push(newArgs x)
            
            if len(newArgs) == arity {
                return applyFunc(func newArgs)
            }
            return curried(newArgs)
        }
    }
    return curried([])
}

fn applyFunc(func args) {
    if len(args) == 2 { return func(args[0] args[1]) }
    if len(args) == 3 { return func(args[0] args[1] args[2]) }
    return 0
}

add3 = (a b c) => a + b + c
curriedAdd = curry(add3 3)
step1 = curriedAdd(1)
step2 = step1(2)
curryResult = step2(3)

