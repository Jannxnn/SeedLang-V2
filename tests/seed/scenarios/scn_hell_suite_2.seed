mrMapper = (x) => x * x
mrReducer = (acc x) => acc + x
mrResult = mapReduce(mrData mrMapper mrReducer 0)

fn solveNQueens(n) {
    board = []
    i = 0
    while i < n {
        row = []
        j = 0
        while j < n {
            push(row 0)
            j = j + 1
        }
        push(board row)
        i = i + 1
    }
    
    solutions = 0
    
    fn isSafe(row col) {
        i = 0
        while i < row {
            if board[i][col] == 1 { return false }
            i = i + 1
        }
        
        i = row - 1
        j = col - 1
        while i >= 0 && j >= 0 {
            if board[i][j] == 1 { return false }
            i = i - 1
            j = j - 1
        }
        
        i = row - 1
        j = col + 1
        while i >= 0 && j < n {
            if board[i][j] == 1 { return false }
            i = i - 1
            j = j + 1
        }
        
        return true
    }
    
    fn solve(row) {
        if row == n {
            solutions = solutions + 1
            return
        }
        
        col = 0
        while col < n {
            if isSafe(row col) {
                board[row][col] = 1
                solve(row + 1)
                board[row][col] = 0
            }
            col = col + 1
        }
    }
    
    solve(0)
    return solutions
}

queens4 = solveNQueens(4)

fn scheduleTasks(tasks resources) {
    schedule = []
    remaining = []
    for t in tasks { push(remaining t) }
    
    time = 0
    running = []
    
    while len(remaining) > 0 || len(running) > 0 {
        i = 0
        while i < len(running) {
            running[i].remaining = running[i].remaining - 1
            i = i + 1
        }
        
        newRunning = []
        i = 0
        while i < len(running) {
            if running[i].remaining > 0 {
                push(newRunning running[i])
            }
            i = i + 1
        }
        running = newRunning
        
        addRunning = []
        newRemaining = []
        i = 0
        while i < len(remaining) {
            if len(running) + len(addRunning) < resources {
                push(addRunning { task: remaining[i] remaining: remaining[i].duration })
            } else {
                push(newRemaining remaining[i])
            }
            i = i + 1
        }
        
        for r in addRunning { push(running r) }
        remaining = newRemaining
        time = time + 1
        
        if time > 20 { break }
    }
    
    return time
}

taskList = [
    { id: 1 duration: 3 }
    { id: 2 duration: 2 }
    { id: 3 duration: 4 }
    { id: 4 duration: 1 }
]

scheduleTime = scheduleTasks(taskList 2)

trieRoot = {}

fn trieInsert(word) {
    node = trieRoot
    chars = split(word "")
    for c in chars {
        if node[c] == null { node[c] = {} }
        node = node[c]
    }
    node.end = true
}

fn trieSearch(word) {
    node = trieRoot
    chars = split(word "")
    for c in chars {
        if node[c] == null { return false }
        node = node[c]
    }
    return node.end == true
}

fn trieStartsWith(prefix) {
    node = trieRoot
    chars = split(prefix "")
    for c in chars {
        if node[c] == null { return false }
        node = node[c]
    }
    return true
}

