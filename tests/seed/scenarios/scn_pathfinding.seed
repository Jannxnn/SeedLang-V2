// 场景测试 - pathfinding：BFS/A* 等路径搜索算法
// EXPECT: "OK:4"
fn bfs(grid start end) {
    rows = len(grid)
    cols = len(grid[0])
    
    queue = [start]
    visited = {}
    visited[start[0] + "," + start[1]] = true
    distance = {}
    distance[start[0] + "," + start[1]] = 0
    
    directions = [[0 1] [1 0] [0 -1] [-1 0]]
    
    while len(queue) > 0 {
        current = queue[0]
        queue = slice(queue 1 len(queue))
        
        if current[0] == end[0] && current[1] == end[1] {
            return distance[current[0] + "," + current[1]]
        }
        
        for dir in directions {
            newRow = current[0] + dir[0]
            newCol = current[1] + dir[1]
            key = newRow + "," + newCol
            
            if newRow >= 0 && newRow < rows && newCol >= 0 && newCol < cols {
                if visited[key] == null && grid[newRow][newCol] != 1 {
                    visited[key] = true
                    distance[key] = distance[current[0] + "," + current[1]] + 1
                    nextPos = [newRow newCol]
                    push(queue nextPos)
                }
            }
        }
    }
    
    return -1
}

fn dfs(grid start end) {
    rows = len(grid)
    cols = len(grid[0])
    visited = {}
    
    fn explore(pos) {
        if pos[0] < 0 || pos[0] >= rows || pos[1] < 0 || pos[1] >= cols {
            return false
        }
        
        key = pos[0] + "," + pos[1]
        if visited[key] != null || grid[pos[0]][pos[1]] == 1 {
            return false
        }
        
        if pos[0] == end[0] && pos[1] == end[1] {
            return true
        }
        
        visited[key] = true
        
        return explore([pos[0] + 1 pos[1]]) ||
               explore([pos[0] - 1 pos[1]]) ||
               explore([pos[0] pos[1] + 1]) ||
               explore([pos[0] pos[1] - 1])
    }
    
    return explore(start)
}

grid = [
    [0 0 0 0]
    [1 1 0 1]
    [0 0 0 0]
    [0 1 1 0]
]

passed = 0

startA = [0 0]
endA = [3 3]
dist = bfs(grid startA endA)
if dist == 6 { passed = passed + 1 }

reachable = dfs(grid startA endA)
if reachable { passed = passed + 1 }

blockedEnd = [1 1]
blocked = dfs(grid startA blockedEnd)
if blocked == false { passed = passed + 1 }

endB = [1 3]
dist2 = bfs(grid startA endB)
if dist2 == -1 { passed = passed + 1 }

result = "OK:" + toString(passed)
