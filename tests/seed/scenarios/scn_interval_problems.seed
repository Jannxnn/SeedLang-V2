// 场景测试 - interval problems：会议室数量等区间调度问题
// EXPECT: "OK:4"
fn minMeetingRooms(intervals) {
    if len(intervals) == 0 { return 0 }
    
    starts = []
    ends = []
    
    for interval in intervals {
        push(starts interval[0])
        push(ends interval[1])
    }
    
    starts = sort(starts)
    ends = sort(ends)
    
    rooms = 0
    endIdx = 0
    
    for start in starts {
        if start < ends[endIdx] {
            rooms = rooms + 1
        } else {
            endIdx = endIdx + 1
        }
    }
    
    return rooms
}

fn canAttendMeetings(intervals) {
    if len(intervals) <= 1 { return true }
    
    sorted = sort(intervals)
    
    i = 1
    while i < len(sorted) {
        if sorted[i][0] < sorted[i - 1][1] {
            return false
        }
        i = i + 1
    }
    
    return true
}

fn minArrowsBurstBalloons(points) {
    if len(points) == 0 { return 0 }
    
    sorted = sort(points)
    
    arrows = 1
    end = sorted[0][1]
    
    i = 1
    while i < len(sorted) {
        if sorted[i][0] > end {
            arrows = arrows + 1
            end = sorted[i][1]
        } else {
            if sorted[i][1] < end {
                end = sorted[i][1]
            }
        }
        i = i + 1
    }
    
    return arrows
}

fn eraseOverlapIntervals(intervals) {
    if len(intervals) == 0 { return 0 }
    
    sorted = sort(intervals)
    
    count = 0
    end = sorted[0][1]
    
    i = 1
    while i < len(sorted) {
        if sorted[i][0] < end {
            count = count + 1
            if sorted[i][1] < end {
                end = sorted[i][1]
            }
        } else {
            end = sorted[i][1]
        }
        i = i + 1
    }
    
    return count
}

passed = 0

if minMeetingRooms([[0 30] [5 10] [15 20]]) == 2 { passed = passed + 1 }
if canAttendMeetings([[0 30] [5 10] [15 20]]) == false { passed = passed + 1 }
if minArrowsBurstBalloons([[10 16] [2 8] [1 6] [7 12]]) == 2 { passed = passed + 1 }
if eraseOverlapIntervals([[1 2] [2 3] [3 4] [1 3]]) == 1 { passed = passed + 1 }

result = "OK:" + toString(passed)
