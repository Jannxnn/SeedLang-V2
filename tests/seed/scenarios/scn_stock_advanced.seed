// EXPECT: "OK:4"
fn maxProfitIV(k prices) {
    n = len(prices)
    
    if n == 0 || k == 0 { return 0 }
    
    if k >= n / 2 {
        profit = 0
        i = 1
        while i < n {
            if prices[i] > prices[i - 1] {
                profit = profit + prices[i] - prices[i - 1]
            }
            i = i + 1
        }
        return profit
    }
    
    buy = []
    sell = []
    i = 0
    while i <= k {
        push(buy 0-999999)
        push(sell 0)
        i = i + 1
    }
    
    for price in prices {
        i = 1
        while i <= k {
            buy[i] = max(buy[i] sell[i - 1] - price)
            sell[i] = max(sell[i] buy[i] + price)
            i = i + 1
        }
    }
    
    return sell[k]
}

fn maxProfitCooldown(prices) {
    if len(prices) == 0 { return 0 }
    
    n = len(prices)
    hold = -prices[0]
    sold = 0
    rest = 0
    
    i = 1
    while i < n {
        prevHold = hold
        prevSold = sold
        prevRest = rest
        
        hold = max(prevHold prevRest - prices[i])
        sold = prevHold + prices[i]
        rest = max(prevRest prevSold)
        
        i = i + 1
    }
    
    return max(sold rest)
}

fn maxProfitFee(prices fee) {
    if len(prices) == 0 { return 0 }
    
    cash = 0
    hold = -prices[0]
    
    i = 1
    while i < len(prices) {
        cash = max(cash hold + prices[i] - fee)
        hold = max(hold cash - prices[i])
        i = i + 1
    }
    
    return cash
}

passed = 0

if maxProfitIV(2 [2 4 1]) == 2 { passed = passed + 1 }
if maxProfitIV(2 [3 2 6 5 0 3]) == 7 { passed = passed + 1 }
if maxProfitCooldown([1 2 3 0 2]) == 3 { passed = passed + 1 }
if maxProfitFee([1 3 2 8 4 9] 2) == 8 { passed = passed + 1 }

result = "OK:" + toString(passed)
