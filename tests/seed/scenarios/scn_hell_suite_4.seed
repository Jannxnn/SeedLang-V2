lruGet3 = lru.get(1)
lruGet4 = lru.get(3)
lruGet5 = lru.get(4)

// ==================== 18. 最小堆 ====================
fn createMinHeap() {
    heap = []
    
    fn bubbleUp(idx) {
        while idx > 0 {
            parent = floor((idx - 1) / 2)
            if heap[parent] <= heap[idx] { break }
            temp = heap[parent]
            heap[parent] = heap[idx]
            heap[idx] = temp
            idx = parent
        }
    }
    
    fn bubbleDown(idx) {
        n = len(heap)
        while true {
            left = 2 * idx + 1
            right = 2 * idx + 2
            smallest = idx
            
            if left < n && heap[left] < heap[smallest] { smallest = left }
            if right < n && heap[right] < heap[smallest] { smallest = right }
            
            if smallest == idx { break }
            
            temp = heap[idx]
            heap[idx] = heap[smallest]
            heap[smallest] = temp
            idx = smallest
        }
    }
    
    return {
        push: fn(val) {
            push(heap val)
            bubbleUp(len(heap) - 1)
        }
        
        pop: fn() {
            if len(heap) == 0 { return null }
            result = heap[0]
            heap[0] = heap[len(heap) - 1]
            heap = slice(heap 0 len(heap) - 1)
            if len(heap) > 0 { bubbleDown(0) }
            return result
        }
        
        peek: fn() {
            if len(heap) == 0 { return null }
            return heap[0]
        }
        
        size: fn() { return len(heap) }
    }
}

minHeap = createMinHeap()
minHeap.push(5)
minHeap.push(3)
minHeap.push(7)
minHeap.push(1)
heapPeek = minHeap.peek()
heapPop1 = minHeap.pop()
heapPop2 = minHeap.pop()

// ==================== 19. 滑动窗口最大值 ====================
fn maxSlidingWindow(nums k) {
    deque = []
    result = []
    
    i = 0
    while i < len(nums) {
        while len(deque) > 0 && deque[0] < i - k + 1 {
            deque = slice(deque 1 len(deque))
        }
        
        while len(deque) > 0 && nums[deque[len(deque) - 1]] < nums[i] {
            deque = slice(deque 0 len(deque) - 1)
        }
        
        push(deque i)
        
        if i >= k - 1 {
            push(result nums[deque[0]])
        }
        
        i = i + 1
    }
    
    return result
}

windowArr = [1 3 -1 -3 5 3 6 7]
windowResult = maxSlidingWindow(windowArr 3)
windowFirst = windowResult[0]
windowLast = windowResult[len(windowResult) - 1]

