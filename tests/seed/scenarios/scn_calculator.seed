// 场景测试 - calculator：表达式计算器（含括号优先级解析）
// EXPECT: "OK:4"
fn calculate(s) {
    stack = []
    num = 0
    sign = 1
    result = 0
    
    i = 0
    while i < len(s) {
        c = charAt(s i)
        
        if c >= "0" && c <= "9" {
            num = num * 10 + (c - 48)
        } else {
            if c == "+" {
                result = result + sign * num
                num = 0
                sign = 1
            } else {
                if c == "-" {
                    result = result + sign * num
                    num = 0
                    sign = -1
                } else {
                    if c == "(" {
                        push(stack result)
                        push(stack sign)
                        result = 0
                        sign = 1
                    } else {
                        if c == ")" {
                            result = result + sign * num
                            num = 0
                            result = result * stack[len(stack) - 1]
                            stack = slice(stack 0 len(stack) - 1)
                            result = result + stack[len(stack) - 1]
                            stack = slice(stack 0 len(stack) - 1)
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    
    return result + sign * num
}

fn calculate2(s) {
    stack = []
    num = 0
    sign = "+"
    
    i = 0
    while i <= len(s) {
        c = " "
        if i < len(s) { c = charAt(s i) }
        
        if c >= "0" && c <= "9" {
            num = num * 10 + (c - 48)
        } else {
            if c == " " && i < len(s) {
                i = i + 1
                continue
            }
            
            if sign == "+" {
                push(stack num)
            } else {
                if sign == "-" {
                    push(stack -num)
                } else {
                    if sign == "*" {
                        stack[len(stack) - 1] = stack[len(stack) - 1] * num
                    } else {
                        if sign == "/" {
                            stack[len(stack) - 1] = floor(stack[len(stack) - 1] / num)
                        }
                    }
                }
            }
            
            num = 0
            sign = c
        }
        i = i + 1
    }
    
    result = 0
    for n in stack { result = result + n }
    return result
}

passed = 0

if calculate("1 + 1") == 2 { passed = passed + 1 }
if calculate(" 2-1 + 2 ") == 3 { passed = passed + 1 }
if calculate2("3+2*2") == 7 { passed = passed + 1 }
if calculate2(" 3/2 ") == 1 { passed = passed + 1 }

result = "OK:" + toString(passed)
