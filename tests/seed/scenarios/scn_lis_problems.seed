// 场景测试 - lis problems：最长递增子序列（LIS）
// EXPECT: "OK:4"
fn lengthOfLIS(nums) {
    if len(nums) == 0 { return 0 }
    
    tails = [nums[0]]
    
    i = 1
    while i < len(nums) {
        if nums[i] > tails[len(tails) - 1] {
            push(tails nums[i])
        } else {
            left = 0
            right = len(tails) - 1
            
            while left < right {
                mid = floor((left + right) / 2)
                if tails[mid] < nums[i] {
                    left = mid + 1
                } else {
                    right = mid
                }
            }
            
            tails[left] = nums[i]
        }
        i = i + 1
    }
    
    return len(tails)
}

fn findNumberOfLIS(nums) {
    if len(nums) == 0 { return 0 }
    
    lengths = []
    counts = []
    
    i = 0
    while i < len(nums) {
        push(lengths 1)
        push(counts 1)
        i = i + 1
    }
    
    maxLen = 1
    
    i = 1
    while i < len(nums) {
        j = 0
        while j < i {
            if nums[j] < nums[i] {
                if lengths[j] + 1 > lengths[i] {
                    lengths[i] = lengths[j] + 1
                    counts[i] = counts[j]
                } else {
                    if lengths[j] + 1 == lengths[i] {
                        counts[i] = counts[i] + counts[j]
                    }
                }
            }
            j = j + 1
        }
        if lengths[i] > maxLen { maxLen = lengths[i] }
        i = i + 1
    }
    
    result = 0
    i = 0
    while i < len(nums) {
        if lengths[i] == maxLen {
            result = result + counts[i]
        }
        i = i + 1
    }
    
    return result
}

fn increasingTriplet(nums) {
    first = null
    second = null
    
    for n in nums {
        if first == null || n <= first {
            first = n
        } else {
            if second == null || n <= second {
                second = n
            } else {
                return true
            }
        }
    }
    
    return false
}

passed = 0

if lengthOfLIS([10 9 2 5 3 7 101 18]) == 4 { passed = passed + 1 }
if findNumberOfLIS([1 3 5 4 7]) == 2 { passed = passed + 1 }
if increasingTriplet([1 2 3 4 5]) { passed = passed + 1 }
if increasingTriplet([5 4 3 2 1]) == false { passed = passed + 1 }

result = "OK:" + toString(passed)
