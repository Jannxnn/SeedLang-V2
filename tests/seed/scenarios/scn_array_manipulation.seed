// 场景测试 - array manipulation：数组查找消失数字等操作技巧
// EXPECT: "OK:4"
fn findDisappearedNumbers(nums) {
    result = []
    
    for n in nums {
        idx = abs(n) - 1
        if nums[idx] > 0 {
            nums[idx] = -nums[idx]
        }
    }
    
    i = 0
    while i < len(nums) {
        if nums[i] > 0 {
            push(result i + 1)
        }
        i = i + 1
    }
    
    return result
}

fn findDuplicates(nums) {
    result = []
    
    for n in nums {
        idx = abs(n) - 1
        if nums[idx] < 0 {
            push(result abs(n))
        } else {
            nums[idx] = -nums[idx]
        }
    }
    
    return result
}

fn firstMissingPositive(nums) {
    n = len(nums)
    
    i = 0
    while i < n {
        while nums[i] > 0 && nums[i] <= n && nums[nums[i] - 1] != nums[i] {
            temp = nums[i]
            nums[i] = nums[temp - 1]
            nums[temp - 1] = temp
        }
        i = i + 1
    }
    
    i = 0
    while i < n {
        if nums[i] != i + 1 {
            return i + 1
        }
        i = i + 1
    }
    
    return n + 1
}

passed = 0

disappeared = findDisappearedNumbers([4 3 2 7 8 2 3 1])
if len(disappeared) == 2 { passed = passed + 1 }

duplicates = findDuplicates([4 3 2 7 8 2 3 1])
if len(duplicates) == 2 { passed = passed + 1 }

if firstMissingPositive([1 2 0]) == 3 { passed = passed + 1 }
if firstMissingPositive([3 4 -1 1]) == 2 { passed = passed + 1 }

result = "OK:" + toString(passed)
