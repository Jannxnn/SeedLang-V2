// 场景测试 - bubble sort edges：冒泡排序的边界条件与优化
// EXPECT: "11:90"
arr = [64 34 25 12 22 11 90]
i = 0
n = len(arr)
while i < n - 1 {
    j = 0
    while j < n - i - 1 {
        if arr[j] > arr[j + 1] {
            t = arr[j]
            arr[j] = arr[j + 1]
            arr[j + 1] = t
        }
        j = j + 1
    }
    i = i + 1
}
result = toString(arr[0]) + ":" + toString(arr[n - 1])
