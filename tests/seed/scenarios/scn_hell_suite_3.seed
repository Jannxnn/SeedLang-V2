// 场景测试 - hell suite 3（地狱级综合）：极端边界条件极限挑战
// EXPECT: "OK:20"
// 地狱级极限测试套件 III - 极端边界条件

// ==================== 1. 零值边界测试 ====================
fn zeroBoundary() {
    a = 0
    b = -0
    c = 0.0
    d = -0.0
    
    results = []
    
    push(results a == b)
    push(results b == c)
    push(results c == d)
    push(results a + b == 0)
    push(results a * 100 == 0)
    push(results 0 / 1 == 0)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

zeroTests = zeroBoundary()

// ==================== 2. 极大数处理 ====================
fn largeNumbers() {
    a = 999999999
    b = 1000000000
    c = a + b
    d = b - a
    e = a * 2
    f = b / 2
    
    sum = c + d + e + f
    return sum
}

largeNumResult = largeNumbers()

// ==================== 3. 极小数处理 ====================
fn smallNumbers() {
    a = 0.000001
    b = 0.000002
    c = a + b
    d = b - a
    e = a * 1000
    f = b / 2
    
    sum = c + d + e + f
    return floor(sum * 1000000)
}

smallNumResult = smallNumbers()

// ==================== 4. 空值边界测试 ====================
fn nullBoundary() {
    a = null
    b = []
    c = {}
    d = ""
    
    results = []
    
    push(results a == null)
    push(results len(b) == 0)
    push(results len(keys(c)) == 0)
    push(results len(d) == 0)
    push(results type(a) == "null")
    push(results type(b) == "array")
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

nullTests = nullBoundary()

// ==================== 5. 字符串边界测试 ====================
fn stringBoundary() {
    empty = ""
    single = "a"
    space = " "
    newline = "\n"
    tab = "\t"
    
    results = []
    
    push(results len(empty) == 0)
    push(results len(single) == 1)
    push(results len(space) == 1)
    push(results len(newline) == 1)
    push(results len(tab) == 1)
    push(results charAt(single 0) == "a")
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

stringTests = stringBoundary()

// ==================== 6. 数组边界测试 ====================
fn arrayBoundary() {
    empty = []
    single = [1]
    nested = [[1]]
    deep = [[[[1]]]]
    
    results = []
    
    push(results len(empty) == 0)
    push(results len(single) == 1)
    push(results single[0] == 1)
    push(results nested[0][0] == 1)
    push(results deep[0][0][0][0] == 1)
    push(results len(deep[0]) == 1)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

arrayTests = arrayBoundary()

// ==================== 7. 对象边界测试 ====================
fn objectBoundary() {
    empty = {}
    single = { a: 1 }
    nested = { a: { b: 1 } }
    deep = { a: { b: { c: { d: 1 } } } }
    
    results = []
    
    push(results len(keys(empty)) == 0)
    push(results len(keys(single)) == 1)
    push(results single.a == 1)
    push(results nested.a.b == 1)
    push(results deep.a.b.c.d == 1)
    push(results len(keys(deep)) == 1)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

objectTests = objectBoundary()

// ==================== 8. 循环边界测试 ====================
fn loopBoundary() {
    sum = 0
    
    i = 0
    while i < 0 {
        sum = sum + 1
        i = i + 1
    }
    
    for j in [] {
        sum = sum + 1
    }
    
    for k in {} {
        sum = sum + 1
    }
    
    return sum
}

loopTests = loopBoundary()

// ==================== 9. 条件边界测试 ====================
fn conditionBoundary() {
    results = []
    
    if 0 { push(results 1) }
    if 1 { push(results 2) }
    if -1 { push(results 3) }
    if "" { push(results 4) }
    if "a" { push(results 5) }
    if null { push(results 6) }
    if [] { push(results 7) }
    if [1] { push(results 8) }
    if {} { push(results 9) }
    if { a: 1 } { push(results 10) }
    
    sum = 0
    for r in results { sum = sum + r }
    return sum
}

conditionTests = conditionBoundary()

// ==================== 10. 函数边界测试 ====================
fn functionBoundary() {
    fn noArgs() { return 1 }
    fn oneArg(a) { return a }
    fn manyArgs(a b c d e) { return a + b + c + d + e }
    fn withDefault(a b) { 
        if b == null { b = 10 }
        return a + b 
    }
    
    results = []
    push(results noArgs() == 1)
    push(results oneArg(2) == 2)
    push(results manyArgs(1 2 3 4 5) == 15)
    push(results withDefault(5) == 15)
    push(results withDefault(5 3) == 8)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

functionTests = functionBoundary()

// ==================== 11. 递归深度边界 ====================
fn recurseDepth(n) {
    if n <= 0 { return 0 }
    return 1 + recurseDepth(n - 1)
}

depth50 = recurseDepth(50)

// ==================== 12. 闭包边界测试 ====================
fn closureBoundary() {
    fn outer() {
        x = 1
        fn inner() {
            y = 2
            fn innermost() {
                return x + y
            }
            return innermost
        }
        return inner
    }
    
    middle = outer()
    innermost = middle()
    return innermost()
}

closureResult = closureBoundary()

// ==================== 13. 类型转换边界 ====================
fn typeConversionBoundary() {
    results = []
    
    push(results toInt("0") == 0)
    push(results toInt("1") == 1)
    push(results toInt("-1") == -1)
    push(results toFloat("1.5") == 1.5)
    push(results toString(123) == "123")
    push(results toBool(0) == false)
    push(results toBool(1) == true)
    push(results toBool("") == false)
    push(results toBool("a") == true)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

typeTests = typeConversionBoundary()

// ==================== 14. 数学函数边界 ====================
fn mathBoundary() {
    results = []
    
    push(results abs(0) == 0)
    push(results abs(-1) == 1)
    push(results abs(1) == 1)
    push(results floor(1.9) == 1)
    push(results floor(-1.1) == -2)
    push(results ceil(1.1) == 2)
    push(results ceil(-1.9) == -1)
    push(results round(1.5) == 2)
    push(results round(1.4) == 1)
    push(results min(1 2) == 1)
    push(results max(1 2) == 2)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

mathTests = mathBoundary()

// ==================== 15. 字符串操作边界 ====================
fn stringOpBoundary() {
    results = []
    
    s = "  hello world  "
    
    push(results len(trim(s)) == 11)
    push(results len(upper(s)) == len(s))
    push(results len(lower(s)) == len(s))
    
    parts = split("a,b,c" ",")
    push(results len(parts) == 3)
    
    joined = join([1 2 3] "-")
    push(results joined == "1-2-3")
    
    sub = substring("hello" 1 4)
    push(results sub == "ell")
    
    idx = indexOf("hello" "ll")
    push(results idx == 2)
    
    replaced = replace("hello" "l" "x")
    push(results replaced == "hexxo")
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

stringOpTests = stringOpBoundary()

// ==================== 16. 数组操作边界 ====================
fn arrayOpBoundary() {
    results = []
    
    arr = [1 2 3 4 5]
    
    push(results len(arr) == 5)
    push(results arr[0] == 1)
    push(results arr[4] == 5)
    
    push(arr 6)
    push(results len(arr) == 6)
    
    last = pop(arr)
    push(results last == 6)
    
    first = shift(arr)
    push(results first == 1)
    
    sliced = slice(arr 1 3)
    push(results len(sliced) == 2)
    
    concat1 = concat([1 2] [3 4])
    push(results len(concat1) == 4)
    
    reversed = reverse([1 2 3])
    push(results reversed[0] == 3)
    
    sorted = sort([3 1 2])
    push(results sorted[0] == 1)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

arrayOpTests = arrayOpBoundary()

// ==================== 17. 对象操作边界 ====================
fn objectOpBoundary() {
    results = []
    
    obj = { a: 1 b: 2 c: 3 }
    
    k = keys(obj)
    push(results len(k) == 3)
    
    v = values(obj)
    push(results len(v) == 3)
    
    e = entries(obj)
    push(results len(e) == 3)
    
    merged = merge({ a: 1 } { b: 2 })
    push(results len(keys(merged)) == 2)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

objectOpTests = objectOpBoundary()

// ==================== 18. 异常边界测试 ====================
fn exceptionBoundary() {
    results = []
    
    try {
        throw "test"
    } catch(e) {
        push(results e == "test")
    }
    
    try {
        try {
            throw "inner"
        } catch(e) {
            push(results e == "inner")
            throw "outer"
        }
    } catch(e) {
        push(results e == "outer")
    }
    
    try {
        x = 1
    } catch(e) {
        x = 2
    }
    push(results x == 1)
    
    count = 0
    for r in results { if r { count = count + 1 } }
    return count
}

exceptionTests = exceptionBoundary()

// ==================== 19. 类边界测试 ====================
class BoundaryClass {
    init(val) {
        this.value = val
    }
    
    getValue() {
        return this.value
    }
    
    setValue(val) {
        this.value = val
    }
    
    add(other) {
        return BoundaryClass(this.value + other.value)
    }
}

classInstance1 = BoundaryClass(10)
classInstance2 = BoundaryClass(20)
classSum = classInstance1.add(classInstance2)
classResult = classSum.getValue()

// ==================== 20. 综合边界测试 ====================
passed = 0

if zeroTests == 6 { passed = passed + 1 }
if largeNumResult == 4499999998 { passed = passed + 1 }
if smallNumResult == 1005 { passed = passed + 1 }
if nullTests == 6 { passed = passed + 1 }
if stringTests == 6 { passed = passed + 1 }
if arrayTests == 6 { passed = passed + 1 }
if objectTests == 6 { passed = passed + 1 }
if loopTests == 0 { passed = passed + 1 }
if conditionTests == 44 { passed = passed + 1 }
if functionTests == 5 { passed = passed + 1 }
if depth50 == 50 { passed = passed + 1 }
if closureResult == 3 { passed = passed + 1 }
if typeTests == 9 { passed = passed + 1 }
if mathTests == 11 { passed = passed + 1 }
if stringOpTests == 8 { passed = passed + 1 }
if arrayOpTests == 10 { passed = passed + 1 }
if objectOpTests == 4 { passed = passed + 1 }
if exceptionTests == 4 { passed = passed + 1 }
if classResult == 30 { passed = passed + 1 }
if classInstance1.getValue() == 10 { passed = passed + 1 }

result = "OK:" + toString(passed)
