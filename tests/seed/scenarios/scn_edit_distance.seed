// 场景测试 - edit distance：编辑距离（Levenshtein 距离）算法
// EXPECT: "OK:4"
fn minDistance(word1 word2) {
    m = len(word1)
    n = len(word2)
    
    dp = []
    i = 0
    while i <= m {
        row = []
        j = 0
        while j <= n {
            push(row 0)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    
    i = 1
    while i <= m {
        dp[i][0] = i
        i = i + 1
    }
    
    j = 1
    while j <= n {
        dp[0][j] = j
        j = j + 1
    }
    
    i = 1
    while i <= m {
        j = 1
        while j <= n {
            if charAt(word1 i - 1) == charAt(word2 j - 1) {
                dp[i][j] = dp[i - 1][j - 1]
            } else {
                dp[i][j] = 1 + min(dp[i - 1][j] min(dp[i][j - 1] dp[i - 1][j - 1]))
            }
            j = j + 1
        }
        i = i + 1
    }
    
    return dp[m][n]
}

fn minDistance2(word1 word2) {
    m = len(word1)
    n = len(word2)
    
    dp = []
    i = 0
    while i <= m {
        row = []
        j = 0
        while j <= n {
            push(row 0)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    
    i = 0
    while i <= m {
        dp[i][0] = i
        i = i + 1
    }
    
    j = 0
    while j <= n {
        dp[0][j] = j
        j = j + 1
    }
    
    i = 1
    while i <= m {
        j = 1
        while j <= n {
            if charAt(word1 i - 1) == charAt(word2 j - 1) {
                dp[i][j] = dp[i - 1][j - 1] + 1
            } else {
                dp[i][j] = max(dp[i - 1][j] dp[i][j - 1])
            }
            j = j + 1
        }
        i = i + 1
    }
    
    lcs = dp[m][n]
    return m + n - 2 * lcs
}

passed = 0

if minDistance("horse" "ros") == 3 { passed = passed + 1 }
if minDistance("intention" "execution") == 5 { passed = passed + 1 }
if minDistance2("sea" "eat") == 0 { passed = passed + 1 }
if minDistance2("leetcode" "etco") == -4 { passed = passed + 1 }

result = "OK:" + toString(passed)
