// EXPECT: "OK:4"
fn levenshteinDistance(s1 s2) {
    m = len(s1)
    n = len(s2)
    
    if m == 0 { return n }
    if n == 0 { return m }
    
    dp = []
    i = 0
    while i <= m {
        row = []
        j = 0
        while j <= n {
            push(row 0)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    
    i = 0
    while i <= m {
        dp[i][0] = i
        i = i + 1
    }
    
    j = 0
    while j <= n {
        dp[0][j] = j
        j = j + 1
    }
    
    i = 1
    while i <= m {
        j = 1
        while j <= n {
            chars1 = split(s1 "")
            chars2 = split(s2 "")
            cost = 0
            if chars1[i - 1] != chars2[j - 1] { cost = 1 }
            
            dp[i][j] = min(
                dp[i - 1][j] + 1
                min(dp[i][j - 1] + 1 dp[i - 1][j - 1] + cost)
            )
            j = j + 1
        }
        i = i + 1
    }
    
    return dp[m][n]
}

fn longestCommonSubsequence(s1 s2) {
    m = len(s1)
    n = len(s2)
    
    dp = []
    i = 0
    while i <= m {
        row = []
        j = 0
        while j <= n {
            push(row 0)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    
    chars1 = split(s1 "")
    chars2 = split(s2 "")
    
    i = 1
    while i <= m {
        j = 1
        while j <= n {
            if chars1[i - 1] == chars2[j - 1] {
                dp[i][j] = dp[i - 1][j - 1] + 1
            } else {
                dp[i][j] = max(dp[i - 1][j] dp[i][j - 1])
            }
            j = j + 1
        }
        i = i + 1
    }
    
    return dp[m][n]
}

passed = 0
if levenshteinDistance("kitten" "sitting") == 3 { passed = passed + 1 }
if levenshteinDistance("abc" "abc") == 0 { passed = passed + 1 }
if longestCommonSubsequence("ABCD" "ACBD") == 3 { passed = passed + 1 }
if longestCommonSubsequence("abc" "def") == 0 { passed = passed + 1 }

result = "OK:" + toString(passed)
