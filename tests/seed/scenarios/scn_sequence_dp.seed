// 场景测试 - sequence dp：最长递增子序列等序列 DP
// EXPECT: "OK:4"
fn maxEnvelopes(envelopes) {
    sorted = sort(envelopes)
    
    heights = []
    for e in sorted {
        push(heights e[1])
    }
    
    return lengthOfLIS(heights)
}

fn lengthOfLIS(nums) {
    if len(nums) == 0 { return 0 }
    
    tails = [nums[0]]
    
    i = 1
    while i < len(nums) {
        if nums[i] > tails[len(tails) - 1] {
            push(tails nums[i])
        } else {
            j = 0
            while j < len(tails) {
                if tails[j] >= nums[i] {
                    tails[j] = nums[i]
                    break
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    
    return len(tails)
}

fn russianDoll(envelopes) {
    if len(envelopes) == 0 { return 0 }
    
    sorted = []
    for e in envelopes {
        push(sorted e)
    }
    
    i = 0
    while i < len(sorted) - 1 {
        j = i + 1
        while j < len(sorted) {
            if sorted[i][0] > sorted[j][0] || (sorted[i][0] == sorted[j][0] && sorted[i][1] < sorted[j][1]) {
                temp = sorted[i]
                sorted[i] = sorted[j]
                sorted[j] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    
    heights = []
    for e in sorted {
        push(heights e[1])
    }
    
    return lengthOfLIS(heights)
}

fn wiggleMaxLength(nums) {
    if len(nums) < 2 { return len(nums) }
    
    up = 1
    down = 1
    
    i = 1
    while i < len(nums) {
        if nums[i] > nums[i - 1] {
            up = down + 1
        } else {
            if nums[i] < nums[i - 1] {
                down = up + 1
            }
        }
        i = i + 1
    }
    
    return max(up down)
}

passed = 0

if russianDoll([[5 4] [6 4] [6 7] [2 3]]) == 3 { passed = passed + 1 }
if wiggleMaxLength([1 7 4 9 2 5]) == 6 { passed = passed + 1 }
if wiggleMaxLength([1 2 3 4 5 6 7 8 9]) == 2 { passed = passed + 1 }
if lengthOfLIS([0 1 0 3 2 3]) == 4 { passed = passed + 1 }

result = "OK:" + toString(passed)
