// 场景测试 - interval operations：区间插入与合并操作
// EXPECT: "OK:4"
fn insert(intervals newInterval) {
    result = []
    i = 0
    n = len(intervals)
    
    while i < n && intervals[i][1] < newInterval[0] {
        push(result intervals[i])
        i = i + 1
    }
    
    while i < n && intervals[i][0] <= newInterval[1] {
        if intervals[i][0] < newInterval[0] { newInterval[0] = intervals[i][0] }
        if intervals[i][1] > newInterval[1] { newInterval[1] = intervals[i][1] }
        i = i + 1
    }
    push(result newInterval)
    
    while i < n {
        push(result intervals[i])
        i = i + 1
    }
    
    return result
}

fn removeInterval(intervals toBeRemoved) {
    result = []
    
    for interval in intervals {
        if interval[1] <= toBeRemoved[0] || interval[0] >= toBeRemoved[1] {
            push(result interval)
        } else {
            if interval[0] < toBeRemoved[0] {
                leftPart = [interval[0] toBeRemoved[0]]
                push(result leftPart)
            }
            if interval[1] > toBeRemoved[1] {
                rightPart = [toBeRemoved[1] interval[1]]
                push(result rightPart)
            }
        }
    }
    
    return result
}

fn removeCoveredIntervals(intervals) {
    intervals = sort(intervals)
    
    count = 0
    prevEnd = 0
    
    for interval in intervals {
        if interval[1] > prevEnd {
            count = count + 1
            prevEnd = interval[1]
        }
    }
    
    return count
}

