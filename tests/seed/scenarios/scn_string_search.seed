// 场景测试 - string search：字符串搜索（KMP/暴力匹配）
// EXPECT: "OK:4"
fn kmpSearch(text pattern) {
    if len(pattern) == 0 { return 0 }
    
    lps = []
    i = 0
    while i < len(pattern) {
        push(lps 0)
        i = i + 1
    }
    
    len = 0
    i = 1
    while i < len(pattern) {
        if pattern[i] == pattern[len] {
            len = len + 1
            lps[i] = len
            i = i + 1
        } else {
            if len != 0 {
                len = lps[len - 1]
            } else {
                lps[i] = 0
                i = i + 1
            }
        }
    }
    
    i = 0
    j = 0
    while i < len(text) {
        if pattern[j] == text[i] {
            i = i + 1
            j = j + 1
        }
        
        if j == len(pattern) {
            return i - j
        }
        
        if i < len(text) && pattern[j] != text[i] {
            if j != 0 {
                j = lps[j - 1]
            } else {
                i = i + 1
            }
        }
    }
    
    return -1
}

fn rabinKarp(text pattern) {
    n = len(text)
    m = len(pattern)
    
    if m == 0 { return 0 }
    if m > n { return -1 }
    
    base = 256
    mod = 101
    
    patternHash = 0
    textHash = 0
    h = 1
    
    i = 0
    while i < m - 1 {
        h = (h * base) % mod
        i = i + 1
    }
    
    i = 0
    while i < m {
        patternHash = (patternHash * base + charAt(pattern i)) % mod
        textHash = (textHash * base + charAt(text i)) % mod
        i = i + 1
    }
    
    i = 0
    while i <= n - m {
        if patternHash == textHash {
            isMatch = true
            j = 0
            while j < m {
                if charAt(text i + j) != charAt(pattern j) {
                    isMatch = false
                    break
                }
                j = j + 1
            }
            if isMatch { return i }
        }
        
        if i < n - m {
            textHash = (base * (textHash - charAt(text i) * h) + charAt(text i + m)) % mod
            if textHash < 0 { textHash = textHash + mod }
        }
        i = i + 1
    }
    
    return -1
}

passed = 0

if kmpSearch("hello world" "world") == 6 { passed = passed + 1 }
if kmpSearch("hello world" "xyz") == -1 { passed = passed + 1 }
if rabinKarp("abracadabra" "cad") == 4 { passed = passed + 1 }
if rabinKarp("abracadabra" "xyz") == -1 { passed = passed + 1 }

result = "OK:" + toString(passed)
