// 场景测试 - jump game：跳跃游戏（贪心/DP）
// EXPECT: "OK:4"
fn canJump(nums) {
    maxReach = 0
    
    i = 0
    while i < len(nums) {
        if i > maxReach { return false }
        if i + nums[i] > maxReach { maxReach = i + nums[i] }
        if maxReach >= len(nums) - 1 { return true }
        i = i + 1
    }
    
    return true
}

fn jump(nums) {
    if len(nums) <= 1 { return 0 }
    
    jumps = 0
    currentEnd = 0
    farthest = 0
    
    i = 0
    while i < len(nums) - 1 {
        if i + nums[i] > farthest { farthest = i + nums[i] }
        
        if i == currentEnd {
            jumps = jumps + 1
            currentEnd = farthest
        }
        i = i + 1
    }
    
    return jumps
}

fn canReach(arr start) {
    visited = {}
    
    fn dfs(idx) {
        if idx < 0 || idx >= len(arr) { return false }
        if visited[idx] != null { return false }
        if arr[idx] == 0 { return true }
        
        visited[idx] = true
        
        return dfs(idx + arr[idx]) || dfs(idx - arr[idx])
    }
    
    return dfs(start)
}

passed = 0

if canJump([2 3 1 1 4]) { passed = passed + 1 }
if canJump([3 2 1 0 4]) == false { passed = passed + 1 }
if jump([2 3 1 1 4]) == 2 { passed = passed + 1 }
if canReach([4 2 3 0 3 1 2] 5) { passed = passed + 1 }

result = "OK:" + toString(passed)
