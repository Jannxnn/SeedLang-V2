// 场景测试 - prime numbers：素数判断与素数筛算法
// EXPECT: "OK:4"
fn isPrime(n) {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    return true
}

fn sieveOfEratosthenes(limit) {
    isPrimeArr = []
    i = 0
    while i <= limit {
        push(isPrimeArr true)
        i = i + 1
    }
    
    isPrimeArr[0] = false
    isPrimeArr[1] = false
    
    p = 2
    while p * p <= limit {
        if isPrimeArr[p] {
            multiple = p * p
            while multiple <= limit {
                isPrimeArr[multiple] = false
                multiple = multiple + p
            }
        }
        p = p + 1
    }
    
    primes = []
    i = 2
    while i <= limit {
        if isPrimeArr[i] {
            push(primes i)
        }
        i = i + 1
    }
    return primes
}

primes = sieveOfEratosthenes(30)

passed = 0
if isPrime(17) { passed = passed + 1 }
if isPrime(18) == false { passed = passed + 1 }
if len(primes) == 10 { passed = passed + 1 }
if primes[0] == 2 { passed = passed + 1 }

result = "OK:" + toString(passed)
