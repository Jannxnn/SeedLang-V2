// 场景测试 - run length encoding：游程编码压缩/解压
// EXPECT: "OK:4"
fn encode(str) {
    result = ""
    chars = split(str "")
    i = 0
    while i < len(chars) {
        char = chars[i]
        count = 1
        while i + count < len(chars) && chars[i + count] == char {
            count = count + 1
        }
        result = result + toString(count) + char
        i = i + count
    }
    return result
}

fn decode(str) {
    result = ""
    i = 0
    while i < len(str) {
        numStr = ""
        while i < len(str) {
            c = charAt(str i)
            if c >= "0" && c <= "9" {
                numStr = numStr + c
                i = i + 1
            } else {
                break
            }
        }
        if i < len(str) {
            char = charAt(str i)
            count = toInt(numStr)
            j = 0
            while j < count {
                result = result + char
                j = j + 1
            }
            i = i + 1
        }
    }
    return result
}

original = "aaabbc"
encoded = encode(original)
decoded = decode(encoded)

passed = 0
if encoded == "3a2b1c" { passed = passed + 1 }
if decoded == original { passed = passed + 1 }

encoded2 = encode("hello")
if encoded2 == "1h1e2l1o" { passed = passed + 1 }
if decode("2a3b1c") == "aabbbc" { passed = passed + 1 }

result = "OK:" + toString(passed)
