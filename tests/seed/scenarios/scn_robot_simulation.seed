// 场景测试 - robot simulation：机器人运动模拟与边界判定
// EXPECT: "OK:4"
fn isRobotBounded(instructions) {
    x = 0
    y = 0
    dir = 0
    directions = [[0 1] [1 0] [0 -1] [-1 0]]
    
    for c in split(instructions "") {
        if c == "G" {
            x = x + directions[dir][0]
            y = y + directions[dir][1]
        } else {
            if c == "L" {
                dir = (dir + 3) % 4
            } else {
                dir = (dir + 1) % 4
            }
        }
    }
    
    return (x == 0 && y == 0) || dir != 0
}

fn judgeCircle(moves) {
    x = 0
    y = 0
    
    for c in split(moves "") {
        if c == "U" { y = y + 1 }
        if c == "D" { y = y - 1 }
        if c == "L" { x = x - 1 }
        if c == "R" { x = x + 1 }
    }
    
    return x == 0 && y == 0
}

fn robotSim(commands obstacles) {
    obstacleSet = {}
    for obs in obstacles {
        key = obs[0] + "," + obs[1]
        obstacleSet[key] = true
    }
    
    x = 0
    y = 0
    dir = 0
    directions = [[0 1] [1 0] [0 -1] [-1 0]]
    maxDist = 0
    
    for cmd in commands {
        if cmd == -2 {
            dir = (dir + 3) % 4
        } else {
            if cmd == -1 {
                dir = (dir + 1) % 4
            } else {
                i = 0
                while i < cmd {
                    nextX = x + directions[dir][0]
                    nextY = y + directions[dir][1]
                    
                    key = nextX + "," + nextY
                    if obstacleSet[key] != null {
                        break
                    }
                    
                    x = nextX
                    y = nextY
                    
                    dist = x * x + y * y
                    if dist > maxDist { maxDist = dist }
                    
                    i = i + 1
                }
            }
        }
    }
    
    return maxDist
}

passed = 0

if isRobotBounded("GGLLGG") { passed = passed + 1 }
if judgeCircle("UD") { passed = passed + 1 }
if judgeCircle("LL") == false { passed = passed + 1 }
if robotSim([4 -1 3] []) == 25 { passed = passed + 1 }

result = "OK:" + toString(passed)
