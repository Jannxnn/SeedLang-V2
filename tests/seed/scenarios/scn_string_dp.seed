// 场景测试 - string dp：字符串 DP（不同子序列/编辑距离）
// EXPECT: "OK:4"
fn numDistinct(s t) {
    m = len(s)
    n = len(t)
    
    dp = []
    i = 0
    while i <= m {
        row = []
        j = 0
        while j <= n {
            push(row 0)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    
    i = 0
    while i <= m {
        dp[i][0] = 1
        i = i + 1
    }
    
    i = 1
    while i <= m {
        j = 1
        while j <= n {
            dp[i][j] = dp[i - 1][j]
            
            if charAt(s i - 1) == charAt(t j - 1) {
                dp[i][j] = dp[i][j] + dp[i - 1][j - 1]
            }
            j = j + 1
        }
        i = i + 1
    }
    
    return dp[m][n]
}

fn isInterleave(s1 s2 s3) {
    if len(s1) + len(s2) != len(s3) { return false }
    
    dp = []
    i = 0
    while i <= len(s1) {
        row = []
        j = 0
        while j <= len(s2) {
            push(row false)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    dp[0][0] = true
    
    i = 1
    while i <= len(s1) {
        dp[i][0] = dp[i - 1][0] && charAt(s1 i - 1) == charAt(s3 i - 1)
        i = i + 1
    }
    
    j = 1
    while j <= len(s2) {
        dp[0][j] = dp[0][j - 1] && charAt(s2 j - 1) == charAt(s3 j - 1)
        j = j + 1
    }
    
    i = 1
    while i <= len(s1) {
        j = 1
        while j <= len(s2) {
            dp[i][j] = (dp[i - 1][j] && charAt(s1 i - 1) == charAt(s3 i + j - 1)) ||
                       (dp[i][j - 1] && charAt(s2 j - 1) == charAt(s3 i + j - 1))
            j = j + 1
        }
        i = i + 1
    }
    
    return dp[len(s1)][len(s2)]
}

passed = 0

if numDistinct("rabbbit" "rabbit") == 3 { passed = passed + 1 }
if numDistinct("babgbag" "bag") == 5 { passed = passed + 1 }
if isInterleave("aabcc" "dbbca" "aadbbcbcac") { passed = passed + 1 }
if isInterleave("aabcc" "dbbca" "aadbbbaccc") == false { passed = passed + 1 }

result = "OK:" + toString(passed)
