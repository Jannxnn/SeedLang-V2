// EXPECT: "OK:4"
fn longestCommonPrefix(strs) {
    if len(strs) == 0 { return "" }
    
    prefix = strs[0]
    i = 1
    while i < len(strs) {
        while indexOf(strs[i] prefix) != 0 {
            prefix = substring(prefix 0 len(prefix) - 1)
            if len(prefix) == 0 { return "" }
        }
        i = i + 1
    }
    return prefix
}

fn groupAnagrams(strs) {
    groups = {}
    for str in strs {
        chars = split(str "")
        sorted = join(sort(chars) "")
        if groups[sorted] == null {
            groups[sorted] = []
        }
        push(groups[sorted] str)
    }
    return groups
}

fn isValidParentheses(s) {
    stack = []
    pairs = { "(": ")" "[": "]" "{": "}" }
    chars = split(s "")
    
    for char in chars {
        if pairs[char] != null {
            push(stack char)
        } else {
            if len(stack) == 0 { return false }
            top = stack[len(stack) - 1]
            stack = slice(stack 0 len(stack) - 1)
            if pairs[top] != char { return false }
        }
    }
    return len(stack) == 0
}

passed = 0

if longestCommonPrefix(["flower" "flow" "flight"]) == "fl" { passed = passed + 1 }

groups = groupAnagrams(["eat" "tea" "tan" "ate" "nat" "bat"])
if len(keys(groups)) == 3 { passed = passed + 1 }

if isValidParentheses("()[]{}") { passed = passed + 1 }
if isValidParentheses("([)]") == false { passed = passed + 1 }

result = "OK:" + toString(passed)
