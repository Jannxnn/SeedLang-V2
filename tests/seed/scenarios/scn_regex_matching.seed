// 场景测试 - regex matching：通配符匹配（. * 正则）
// EXPECT: "OK:4"
fn isMatch(s p) {
    m = len(s)
    n = len(p)
    
    dp = []
    i = 0
    while i <= m {
        row = []
        j = 0
        while j <= n {
            push(row false)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    dp[0][0] = true
    
    j = 1
    while j <= n {
        if charAt(p j - 1) == "*" {
            dp[0][j] = dp[0][j - 2]
        }
        j = j + 1
    }
    
    i = 1
    while i <= m {
        j = 1
        while j <= n {
            if charAt(p j - 1) == "." || charAt(p j - 1) == charAt(s i - 1) {
                dp[i][j] = dp[i - 1][j - 1]
            } else {
                if charAt(p j - 1) == "*" {
                    dp[i][j] = dp[i][j - 2]
                    if charAt(p j - 2) == "." || charAt(p j - 2) == charAt(s i - 1) {
                        dp[i][j] = dp[i][j] || dp[i - 1][j]
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    
    return dp[m][n]
}

fn isMatchWildcard(s p) {
    m = len(s)
    n = len(p)
    
    dp = []
    i = 0
    while i <= m {
        row = []
        j = 0
        while j <= n {
            push(row false)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    dp[0][0] = true
    
    j = 1
    while j <= n {
        if charAt(p j - 1) == "*" {
            dp[0][j] = dp[0][j - 1]
        }
        j = j + 1
    }
    
    i = 1
    while i <= m {
        j = 1
        while j <= n {
            if charAt(p j - 1) == "?" || charAt(p j - 1) == charAt(s i - 1) {
                dp[i][j] = dp[i - 1][j - 1]
            } else {
                if charAt(p j - 1) == "*" {
                    dp[i][j] = dp[i - 1][j] || dp[i][j - 1]
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    
    return dp[m][n]
}

passed = 0

if isMatch("aa" "a") == false { passed = passed + 1 }
if isMatch("aa" "a*") { passed = passed + 1 }
if isMatch("ab" ".*") { passed = passed + 1 }
if isMatchWildcard("adceb" "*a*b") { passed = passed + 1 }

result = "OK:" + toString(passed)
