// 场景测试 - binary search range：查找最接近目标值的 K 个元素
// EXPECT: "OK:4"
fn findClosestElements(arr k x) {
    left = 0
    right = len(arr) - k
    
    while left < right {
        mid = floor((left + right) / 2)
        
        if x - arr[mid] > arr[mid + k] - x {
            left = mid + 1
        } else {
            right = mid
        }
    }
    
    result = []
    i = left
    while i < left + k {
        push(result arr[i])
        i = i + 1
    }
    
    return result
}

fn searchRange(nums target) {
    fn findFirst() {
        left = 0
        right = len(nums) - 1
        result = -1
        
        while left <= right {
            mid = floor((left + right) / 2)
            
            if nums[mid] == target {
                result = mid
                right = mid - 1
            } else {
                if nums[mid] < target {
                    left = mid + 1
                } else {
                    right = mid - 1
                }
            }
        }
        
        return result
    }
    
    fn findLast() {
        left = 0
        right = len(nums) - 1
        result = -1
        
        while left <= right {
            mid = floor((left + right) / 2)
            
            if nums[mid] == target {
                result = mid
                left = mid + 1
            } else {
                if nums[mid] < target {
                    left = mid + 1
                } else {
                    right = mid - 1
                }
            }
        }
        
        return result
    }
    
    return [findFirst() findLast()]
}

passed = 0

closest = findClosestElements([1 2 3 4 5] 4 3)
if len(closest) == 4 && closest[0] == 1 { passed = passed + 1 }

range1 = searchRange([5 7 7 8 8 10] 8)
if range1[0] == 3 && range1[1] == 4 { passed = passed + 1 }

range2 = searchRange([5 7 7 8 8 10] 6)
if range2[0] == -1 && range2[1] == -1 { passed = passed + 1 }

closest2 = findClosestElements([1 1 1 10 10 10] 1 9)
if closest2[0] == 10 { passed = passed + 1 }

result = "OK:" + toString(passed)
