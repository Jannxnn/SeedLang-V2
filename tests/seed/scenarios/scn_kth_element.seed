// 场景测试 - kth element：第 K 大元素（快速选择/堆）
// EXPECT: "OK:4"
fn findKthLargest(nums k) {
    fn partition(arr left right) {
        pivot = arr[right]
        i = left
        
        j = left
        while j < right {
            if arr[j] >= pivot {
                temp = arr[i]
                arr[i] = arr[j]
                arr[j] = temp
                i = i + 1
            }
            j = j + 1
        }
        
        temp = arr[i]
        arr[i] = arr[right]
        arr[right] = temp
        return i
    }
    
    fn quickSelect(arr left right k) {
        if left == right { return arr[left] }
        
        pivotIndex = partition(arr left right)
        
        if k == pivotIndex {
            return arr[k]
        } else {
            if k < pivotIndex {
                return quickSelect(arr left pivotIndex - 1 k)
            } else {
                return quickSelect(arr pivotIndex + 1 right k)
            }
        }
    }
    
    return quickSelect(nums 0 len(nums) - 1 k - 1)
}

fn topKFrequent(nums k) {
    count = {}
    for n in nums {
        if count[n] == null { count[n] = 0 }
        count[n] = count[n] + 1
    }
    
    pairs = []
    for key in keys(count) {
        pair = [count[key] key]
        push(pairs pair)
    }
    
    pairs = sort(pairs)
    pairs = reverse(pairs)
    
    result = []
    i = 0
    while i < k && i < len(pairs) {
        push(result pairs[i][1])
        i = i + 1
    }
    
    return result
}

fn kClosestPoints(points k) {
    points = sort(points)
    
    result = []
    i = 0
    while i < k {
        push(result points[i])
        i = i + 1
    }
    
    return result
}

passed = 0

if findKthLargest([3 2 1 5 6 4] 2) == 5 { passed = passed + 1 }

topK = topKFrequent([1 1 1 2 2 3] 2)
if len(topK) == 2 { passed = passed + 1 }

if findKthLargest([1] 1) == 1 { passed = passed + 1 }

topK2 = topKFrequent([1] 1)
if topK2[0] == 1 { passed = passed + 1 }

result = "OK:" + toString(passed)
