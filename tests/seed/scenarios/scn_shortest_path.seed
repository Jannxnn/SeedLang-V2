// 场景测试 - shortest path：最短路径（Bellman-Ford/Dijkstra）
// EXPECT: "OK:4"
fn findCheapestPrice(n flights src dst k) {
    prices = []
    i = 0
    while i < n {
        push(prices 999999)
        i = i + 1
    }
    prices[src] = 0
    
    i = 0
    while i <= k {
        tempPrices = []
        for p in prices { push(tempPrices p) }
        
        for flight in flights {
            from = flight[0]
            to = flight[1]
            price = flight[2]
            
            if prices[from] != 999999 {
                newPrice = prices[from] + price
                if newPrice < tempPrices[to] {
                    tempPrices[to] = newPrice
                }
            }
        }
        
        prices = tempPrices
        i = i + 1
    }
    
    if prices[dst] == 999999 { return -1 }
    return prices[dst]
}

fn networkDelayTime(times n k) {
    dist = []
    i = 0
    while i <= n {
        push(dist 999999)
        i = i + 1
    }
    dist[k] = 0
    
    i = 0
    while i < n {
        updated = false
        
        for time in times {
            u = time[0]
            v = time[1]
            w = time[2]
            
            if dist[u] != 999999 && dist[u] + w < dist[v] {
                dist[v] = dist[u] + w
                updated = true
            }
        }
        
        if updated == false { break }
        i = i + 1
    }
    
    maxDist = 0
    i = 1
    while i <= n {
        if dist[i] == 999999 { return -1 }
        if dist[i] > maxDist { maxDist = dist[i] }
        i = i + 1
    }
    
    return maxDist
}

passed = 0

flights = [[0 1 100] [1 2 100] [2 0 100] [1 3 600] [2 3 200]]
if findCheapestPrice(4 flights 0 3 1) == 700 { passed = passed + 1 }

times = [[2 1 1] [2 3 1] [3 4 1]]
if networkDelayTime(times 4 2) == 2 { passed = passed + 1 }

flights2 = [[0 1 100]]
if findCheapestPrice(2 flights2 0 1 0) == 100 { passed = passed + 1 }

times2 = [[1 2 1]]
if networkDelayTime(times2 2 1) == 1 { passed = passed + 1 }

result = "OK:" + toString(passed)
