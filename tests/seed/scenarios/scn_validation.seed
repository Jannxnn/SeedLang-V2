// 场景测试 - validation：数值字符串校验等验证逻辑
// EXPECT: "OK:4"
fn isNumber(s) {
    s = trim(s)
    
    if len(s) == 0 { return false }
    
    seenDigit = false
    seenDot = false
    seenE = false
    seenSign = false
    
    i = 0
    while i < len(s) {
        c = charAt(s i)
        
        if c >= "0" && c <= "9" {
            seenDigit = true
        } else {
            if c == "+" || c == "-" {
                if i > 0 && charAt(s i - 1) != "e" && charAt(s i - 1) != "E" {
                    return false
                }
            } else {
                if c == "." {
                    if seenDot || seenE { return false }
                    seenDot = true
                } else {
                    if c == "e" || c == "E" {
                        if seenE || seenDigit == false { return false }
                        seenE = true
                        seenDigit = false
                    } else {
                        return false
                    }
                }
            }
        }
        i = i + 1
    }
    
    return seenDigit
}

fn compareVersion(version1 version2) {
    v1 = split(version1 ".")
    v2 = split(version2 ".")
    
    maxLen = max(len(v1) len(v2))
    
    i = 0
    while i < maxLen {
        n1 = 0
        if i < len(v1) { n1 = toInt(v1[i]) }
        
        n2 = 0
        if i < len(v2) { n2 = toInt(v2[i]) }
        
        if n1 > n2 { return 1 }
        if n1 < n2 { return -1 }
        
        i = i + 1
    }
    
    return 0
}

fn validIPAddress(IP) {
    if indexOf(IP ".") >= 0 {
        parts = split(IP ".")
        if len(parts) != 4 { return "Neither" }
        
        for part in parts {
            if len(part) == 0 || len(part) > 3 { return "Neither" }
            
            i = 0
            while i < len(part) {
                c = charAt(part i)
                if c < "0" || c > "9" { return "Neither" }
                i = i + 1
            }
            
            num = toInt(part)
            if num > 255 { return "Neither" }
            if len(part) > 1 && charAt(part 0) == "0" { return "Neither" }
        }
        
        return "IPv4"
    }
    
    return "Neither"
}

passed = 0

if isNumber("0") { passed = passed + 1 }
if isNumber(" 0.1 ") { passed = passed + 1 }
if isNumber("abc") == false { passed = passed + 1 }
if compareVersion("1.01" "1.001") == 0 { passed = passed + 1 }

result = "OK:" + toString(passed)
