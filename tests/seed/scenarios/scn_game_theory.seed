// 场景测试 - game theory：博弈论问题（我能赢吗 / Nim 游戏）
// EXPECT: "OK:4"
fn canIWin(maxChoosableInteger desiredTotal) {
    if maxChoosableInteger * (maxChoosableInteger + 1) / 2 < desiredTotal { return false }
    if desiredTotal <= 0 { return true }
    
    memo = {}
    
    fn dfs(used remaining) {
        if remaining <= 0 { return false }
        
        key = used
        if memo[key] != null { return memo[key] }
        
        i = 1
        while i <= maxChoosableInteger {
            bit = 1 << i
            if (used & bit) == 0 {
                if dfs(used | bit remaining - i) == false {
                    memo[key] = true
                    return true
                }
            }
            i = i + 1
        }
        
        memo[key] = false
        return false
    }
    
    return dfs(0 desiredTotal)
}

fn predictTheWinner(nums) {
    n = len(nums)
    
    dp = []
    i = 0
    while i < n {
        row = []
        j = 0
        while j < n {
            push(row 0)
            j = j + 1
        }
        push(dp row)
        i = i + 1
    }
    
    i = 0
    while i < n {
        dp[i][i] = nums[i]
        i = i + 1
    }
    
    len = 2
    while len <= n {
        i = 0
        while i <= n - len {
            j = i + len - 1
            dp[i][j] = max(nums[i] - dp[i + 1][j] nums[j] - dp[i][j - 1])
            i = i + 1
        }
        len = len + 1
    }
    
    return dp[0][n - 1] >= 0
}

fn stoneGame(piles) {
    return predictTheWinner(piles)
}

passed = 0

if predictTheWinner([1 5 2]) == false { passed = passed + 1 }
if predictTheWinner([1 5 233 7]) { passed = passed + 1 }
if stoneGame([5 3 4 5]) { passed = passed + 1 }
if stoneGame([3 7 2 5]) { passed = passed + 1 }

result = "OK:" + toString(passed)
