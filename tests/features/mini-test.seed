// 简化测试套件：快速验证 SeedLang 核心语法（变量/运算符/控制流）的基本可用性

passed = 0
failed = 0

fn test(name result expected) {
    if result == expected {
        passed = passed + 1
        print("  [OK] " + name)
    } else {
        failed = failed + 1
        print("  [FAIL] " + name)
    }
}

print("=== SeedLang Test ===")

test("sqrt(16)" sqrt(16) 4)
test("pow(2 3)" pow(2 3) 8)
test("abs(-5)" abs(-5) 5)

print("Passed: " + passed)
print("Failed: " + failed)
