{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SeedLang",
  "scopeName": "source.seedlang",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#symbols"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.seedlang",
          "match": "//.*$"
        },
        {
          "name": "comment.block.seedlang",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.seedlang",
          "match": "\\b(if|else|elif|for|while|in|break|continue|return|switch|case|default)\\b"
        },
        {
          "name": "keyword.declaration.seedlang",
          "match": "\\b(fn|async|await|interface|type|class|import|export|from)\\b"
        },
        {
          "name": "keyword.operator.seedlang",
          "match": "\\b(and|or|not|is)\\b"
        },
        {
          "name": "constant.language.seedlang",
          "match": "\\b(true|false|null|undefined)\\b"
        },
        {
          "name": "constant.other.seedlang",
          "match": "\\b(PI|E)\\b"
        },
        {
          "name": "storage.type.seedlang",
          "match": "\\b(string|number|boolean|array|object|function|any|void)\\b"
        },
        {
          "name": "support.class.gui.seedlang",
          "match": "\\bgui\\b"
        },
        {
          "name": "support.function.builtin.seedlang",
          "match": "\\b(len|push|pop|map|filter|reduce|sort|reverse|slice|range|print|upper|lower|trim|contains|indexOf|replace|substring|abs|floor|ceil|round|pow|sqrt|random|randomInt|min|max|toString|toInt|toBool|type|isArray|isObject|isString|isNumber|sleep|time|mod)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.seedlang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.seedlang",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.seedlang",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.seedlang",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.seedlang",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.template.expression.seedlang",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "#numbers"
                },
                {
                  "include": "#identifiers"
                }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.seedlang",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.seedlang",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.numeric.hex.seedlang",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.seedlang",
          "match": "\\b0b[01]+\\b"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "entity.name.tag.statement.seedlang",
          "match": "![swo]",
          "captures": {
            "0": {
              "name": "keyword.control.statement.seedlang"
            }
          }
        },
        {
          "name": "entity.name.tag.seedlang",
          "match": "#[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.tag.noun.seedlang",
          "match": "#n[0-9]+"
        },
        {
          "name": "entity.name.tag.verb.seedlang",
          "match": "#v[A-Z]+"
        },
        {
          "name": "entity.name.tag.text.seedlang",
          "match": "#t"
        },
        {
          "name": "punctuation.definition.statement.seedlang",
          "match": "!"
        },
        {
          "name": "punctuation.definition.question.seedlang",
          "match": "\\?"
        },
        {
          "name": "punctuation.separator.arrow.seedlang",
          "match": "->"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.seedlang",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "entity.name.function.seedlang",
          "match": "\\bfn\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.seedlang"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.seedlang",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.seedlang",
          "match": "(==|!=|<|>|<=|>=)"
        },
        {
          "name": "keyword.operator.assignment.seedlang",
          "match": "(=|\\+=|-=|\\*=|/=)"
        },
        {
          "name": "keyword.operator.logical.seedlang",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arrow.seedlang",
          "match": "=>"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.seedlang",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
